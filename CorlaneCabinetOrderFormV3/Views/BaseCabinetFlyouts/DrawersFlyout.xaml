<local:FlyoutUserControlBase
    x:Class="CorlaneCabinetOrderFormV3.Views.BaseCabinetFlyouts.DrawersFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:CorlaneCabinetOrderFormV3.Views.BaseCabinetFlyouts"
    xmlns:Converters="clr-namespace:CorlaneCabinetOrderFormV3.Converters">
    <local:FlyoutUserControlBase.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Converters:BoolInverter x:Key="BoolInverter"/>
        <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}"/>
        <Style TargetType="CheckBox" BasedOn="{StaticResource FlyoutCheckBox}"/>
        <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
        <Style TargetType="Button" BasedOn="{StaticResource FlyoutButton}"/>
    </local:FlyoutUserControlBase.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <TextBlock Text="Drawers" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

            <Label Content="Number of Drawers:" Padding="0" Margin="0,0,0,4"/>
            <ComboBox Width="60" HorizontalAlignment="Left"
                      ItemsSource="{Binding ListDrwCount, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}"
                      SelectedItem="{Binding DrwCount}"/>

            <StackPanel Visibility="{Binding DrawersStackPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <Label Content="Drawer Front Grain Direction:" Padding="0" Margin="0,10,0,4"/>
                <ComboBox Width="120" HorizontalAlignment="Left"
                          ItemsSource="{Binding ListGrainDirection}"
                          SelectedItem="{Binding DrwFrontGrainDir}"/>

                <Label Content="Drawer Style:" Padding="0" Margin="0,8,0,4"
                       Visibility="{Binding ListDrawerStyleVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <ComboBox Width="320" HorizontalAlignment="Left"
                          ItemsSource="{Binding ListDrawerStyle}"
                          SelectedValue="{Binding DrwStyle, UpdateSourceTrigger=PropertyChanged}"
                          Visibility="{Binding ListDrawerStyleVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <Separator Margin="0,8,0,8"/>

                <!--===== OPENING HEIGHTS =====-->
                <TextBlock Text="Opening Heights" FontSize="18" FontWeight="SemiBold" Margin="0,10,0,6"/>

                <StackPanel Orientation="Horizontal" Visibility="{Binding Opening1Visible, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,6">
                    <TextBlock Text="Opening 1" VerticalAlignment="Center" FontWeight="SemiBold" Width="Auto" Margin="0,0,5,0"/>
                    <TextBox Width="80" VerticalAlignment="Center"
                             IsReadOnly="{Binding Opening1Disabled}"
                             Text="{Binding OpeningHeight1, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="TextBoxGotFocus"/>
                    <CheckBox Content="Supply Drawer Box" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwBoxOpening1}" IsEnabled="{Binding SinkCabinet, Converter={StaticResource BoolInverter}}"/>
                    <CheckBox Content="Drill Slide Holes" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding DrillSlideHolesOpening1}" IsEnabled="{Binding SinkCabinet, Converter={StaticResource BoolInverter}}"/>
                    <CheckBox Content="Include in Sizes List" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwBoxInListOpening1}" IsEnabled="{Binding SinkCabinet, Converter={StaticResource BoolInverter}}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Visibility="{Binding Opening2Visible, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,6">
                    <TextBlock Text="Opening 2" VerticalAlignment="Center" FontWeight="SemiBold" Width="Auto" Margin="0,0,5,0"/>
                    <TextBox Width="80" VerticalAlignment="Center"
                             IsReadOnly="{Binding Opening2Disabled}"
                             Text="{Binding OpeningHeight2, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="TextBoxGotFocus"/>
                    <CheckBox Content="Supply Drawer Box" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwBoxOpening2}"/>
                    <CheckBox Content="Drill Slide Holes" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding DrillSlideHolesOpening2}"/>
                    <CheckBox Content="Include in Sizes List" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwBoxInListOpening2}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Visibility="{Binding Opening3Visible, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,6">
                    <TextBlock Text="Opening 3" VerticalAlignment="Center" FontWeight="SemiBold" Width="Auto" Margin="0,0,5,0"/>
                    <TextBox Width="80" VerticalAlignment="Center"
                             IsReadOnly="{Binding Opening3Disabled}"
                             Text="{Binding OpeningHeight3, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="TextBoxGotFocus"/>
                    <CheckBox Content="Supply Drawer Box" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwBoxOpening3}"/>
                    <CheckBox Content="Drill Slide Holes" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding DrillSlideHolesOpening3}"/>
                    <CheckBox Content="Include in Sizes List" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwBoxInListOpening3}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Visibility="{Binding Opening4Visible, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,6">
                    <TextBlock Text="Opening 4" VerticalAlignment="Center" FontWeight="SemiBold" Width="Auto" Margin="0,0,5,0"/>
                    <TextBox Width="80" VerticalAlignment="Center" IsReadOnly="True"
                             Text="{Binding OpeningHeight4, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="TextBoxGotFocus"/>
                    <CheckBox Content="Supply Drawer Box" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwBoxOpening4}"/>
                    <CheckBox Content="Drill Slide Holes" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding DrillSlideHolesOpening4}"/>
                    <CheckBox Content="Include in Sizes List" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwBoxInListOpening4}"/>
                </StackPanel>

                <Separator Margin="0,8,0,8"/>

                <!--===== DRAWER FRONT HEIGHTS =====-->
                <StackPanel Visibility="{Binding GroupDrawerFrontHeightsVisibility, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="Drw. Front Heights" FontSize="18" FontWeight="SemiBold" Margin="0,10,0,4"/>

                    <StackPanel Orientation="Horizontal" Visibility="{Binding DrwFront1Visible, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,6">
                        <TextBlock Text="Drw. Front 1" VerticalAlignment="Center" FontWeight="SemiBold" Width="Auto" Margin="0,0,5,0"/>
                        <TextBox Width="80" VerticalAlignment="Center"
                                 IsReadOnly="{Binding DrwFront1Disabled}"
                                 Text="{Binding DrwFrontHeight1Edit, UpdateSourceTrigger=PropertyChanged}"
                                 GotFocus="TextBoxGotFocus"/>
                        <CheckBox Content="Supply Slab Drawer Front" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwFront1}"/>
                        <CheckBox Content="Include Drawer Front in Sizes List" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwFrontInList1}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Visibility="{Binding DrwFront2Visible, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,6">
                        <TextBlock Text="Drw. Front 2" VerticalAlignment="Center" FontWeight="SemiBold" Width="Auto" Margin="0,0,5,0"/>
                        <TextBox Width="80" VerticalAlignment="Center"
                                 IsReadOnly="{Binding DrwFront2Disabled}"
                                 Text="{Binding DrwFrontHeight2, UpdateSourceTrigger=PropertyChanged}"
                                 GotFocus="TextBoxGotFocus"/>
                        <CheckBox Content="Supply Slab Drawer Front" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwFront2}"/>
                        <CheckBox Content="Include Drawer Front in Sizes List" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwFrontInList2}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Visibility="{Binding DrwFront3Visible, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,6">
                        <TextBlock Text="Drw. Front 3" VerticalAlignment="Center" FontWeight="SemiBold" Width="Auto" Margin="0,0,5,0"/>
                        <TextBox Width="80" VerticalAlignment="Center"
                                 IsReadOnly="{Binding DrwFront3Disabled}"
                                 Text="{Binding DrwFrontHeight3, UpdateSourceTrigger=PropertyChanged}"
                                 GotFocus="TextBoxGotFocus"/>
                        <CheckBox Content="Supply Slab Drawer Front" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwFront3}"/>
                        <CheckBox Content="Include Drawer Front in Sizes List" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwFrontInList3}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Visibility="{Binding DrwFront4Visible, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,6">
                        <TextBlock Text="Drw. Front 4" VerticalAlignment="Center" FontWeight="SemiBold" Width="Auto" Margin="0,0,5,0"/>
                        <TextBox Width="80" VerticalAlignment="Center" IsReadOnly="True"
                                 Text="{Binding DrwFrontHeight4, UpdateSourceTrigger=PropertyChanged}"
                                 GotFocus="TextBoxGotFocus"/>
                        <CheckBox Content="Supply Slab Drawer Front" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwFront4}"/>
                        <CheckBox Content="Include Drawer Front in Sizes List" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwFrontInList4}"/>
                    </StackPanel>

                    <Separator Margin="0,8,0,8"/>

                    <StackPanel Orientation="Vertical" Margin="0,4,0,4">
                        <CheckBox Content="Equalize Bottom Drawer Fronts" Style="{StaticResource FlyoutCheckBox}" HorizontalAlignment="Left" Margin="8,0,0,10" IsTabStop="False"
                                  IsChecked="{Binding EqualizeBottomDrwFronts}"/>
                        <CheckBox Content="Equalize All Drawer Fronts" Style="{StaticResource FlyoutCheckBox}" HorizontalAlignment="Left" Margin="8,0,0,10" IsTabStop="False"
                                  IsChecked="{Binding EqualizeAllDrwFronts}"/>
                        <Button Content="Load Default Drawer Front Settings" Style="{StaticResource FlyoutButton}" HorizontalAlignment="Left" Margin="8,0,0,10" IsTabStop="False"
                                Command="{Binding LoadDefaultDrwSettingsCommand}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</local:FlyoutUserControlBase>