<local:FlyoutUserControlBase
    x:Class="CorlaneCabinetOrderFormV3.Views.BaseCabinetFlyouts.ToekickFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:CorlaneCabinetOrderFormV3.Views.BaseCabinetFlyouts"
    xmlns:appbehaviors="clr-namespace:CorlaneCabinetOrderFormV3.Behaviors">
    <local:FlyoutUserControlBase.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}"/>
        <Style TargetType="CheckBox" BasedOn="{StaticResource FlyoutCheckBox}"/>
        <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
    </local:FlyoutUserControlBase.Resources>
    <StackPanel>
        <TextBlock Text="Toekick" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <CheckBox Content="Has Toekick" Margin="0,4,0,10" IsChecked="{Binding HasTK}"/>

        <Label Content="Toekick Height" Margin="0,0,0,0" Padding="0"/>
        <TextBox x:Name="textTKHeight" Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
                 Text="{Binding TKHeight, UpdateSourceTrigger=PropertyChanged}"
                 IsEnabled="{Binding HasTK}" GotFocus="TextBoxGotFocus"
                 appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
        <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                   Visibility="{Binding (Validation.HasError), ElementName=textTKHeight, Converter={StaticResource BoolToVisibilityConverter}}"
                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textTKHeight, FallbackValue=''}"/>

        <Label Content="Toekick Depth" Margin="0,8,0,0" Padding="0"/>
        <TextBox x:Name="textTKDepth" Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
                 Text="{Binding TKDepth, UpdateSourceTrigger=PropertyChanged}"
                 IsEnabled="{Binding HasTK}" GotFocus="TextBoxGotFocus"
                 appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
        <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                   Visibility="{Binding (Validation.HasError), ElementName=textTKDepth, Converter={StaticResource BoolToVisibilityConverter}}"
                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textTKDepth, FallbackValue=''}"/>
    </StackPanel>
</local:FlyoutUserControlBase>