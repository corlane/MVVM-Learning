<local:FlyoutUserControlBase
    x:Class="CorlaneCabinetOrderFormV3.Views.BaseCabinetFlyouts.CabinetStyleFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:CorlaneCabinetOrderFormV3.Views.BaseCabinetFlyouts"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors">
    <local:FlyoutUserControlBase.Resources>
        <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}"/>
        <Style TargetType="CheckBox" BasedOn="{StaticResource FlyoutCheckBox}"/>
        <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
        <Style TargetType="ListBox" BasedOn="{StaticResource FlyoutListBox}"/>
    </local:FlyoutUserControlBase.Resources>
    <StackPanel>
        <TextBlock Text="Cabinet Style" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ListBox ItemsSource="{Binding TypeList}"
                 SelectedValue="{Binding Style, Mode=TwoWay}">
            <behaviors:Interaction.Triggers>
                <behaviors:EventTrigger EventName="SelectionChanged">
                    <behaviors:InvokeCommandAction Command="{Binding LoadDefaultsCommand}"/>
                </behaviors:EventTrigger>
            </behaviors:Interaction.Triggers>
        </ListBox>
        <Separator Margin="0,10,0,8"/>
        <CheckBox Content="Sink Cabinet"
                  IsChecked="{Binding SinkCabinet, UpdateSourceTrigger=PropertyChanged}"
                  IsEnabled="{Binding SinkCabinetEnabled}"/>
        <CheckBox Content="Trash Drawer"
                  IsChecked="{Binding TrashDrawer}"
                  IsEnabled="{Binding TrashDrawerEnabled}"/>
        <CheckBox Content="Supply Drw Box" Margin="16,5,0,5"
                  IsChecked="{Binding IncTrashDrwBox}"
                  IsEnabled="{Binding TrashDrawer}"/>
    </StackPanel>
</local:FlyoutUserControlBase>