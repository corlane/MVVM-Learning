<local:FlyoutUserControlBase
    x:Class="CorlaneCabinetOrderFormV3.Views.BaseCabinetFlyouts.DoorsFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:CorlaneCabinetOrderFormV3.Views.BaseCabinetFlyouts"
    xmlns:Converters="clr-namespace:CorlaneCabinetOrderFormV3.Converters">
    <local:FlyoutUserControlBase.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}"/>
        <Style TargetType="CheckBox" BasedOn="{StaticResource FlyoutCheckBox}"/>
        <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
    </local:FlyoutUserControlBase.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <TextBlock Text="Doors" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

            <Label Content="No. of Doors:" Padding="0" Margin="0,0,0,4"/>
            <ComboBox Width="60" HorizontalAlignment="Left"
                      ItemsSource="{Binding ListDoorCount, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}"
                      SelectedItem="{Binding DoorCount}"/>

            <Label Content="Door Grain Direction:" Padding="0" Margin="0,10,0,4"
                   Visibility="{Binding DoorGrainDirVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <ComboBox Width="120" HorizontalAlignment="Left"
                      ItemsSource="{Binding ListGrainDirection}"
                      SelectedItem="{Binding DoorGrainDir}"
                      Visibility="{Binding DoorGrainDirVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <Separator Margin="0,10,0,6"/>

            <CheckBox Content="Supply Slab Doors With Cabinet" Margin="0,4,0,4"
                      IsChecked="{Binding IncDoors}"
                      Visibility="{Binding SupplySlabDoorsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <CheckBox Content="Include Doors In Sizes List" Margin="0,4,0,4"
                      IsChecked="{Binding IncDoorsInList}"
                      Visibility="{Binding IncDoorsInListVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <CheckBox Content="Drill Hinge Plate Mounting Holes" Margin="0,4,0,0"
                      IsChecked="{Binding DrillHingeHoles}"
                      Visibility="{Binding DrillHingeHolesVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </StackPanel>
    </ScrollViewer>
</local:FlyoutUserControlBase>