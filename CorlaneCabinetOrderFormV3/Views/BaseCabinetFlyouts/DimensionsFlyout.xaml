<local:FlyoutUserControlBase
    x:Class="CorlaneCabinetOrderFormV3.Views.BaseCabinetFlyouts.DimensionsFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:CorlaneCabinetOrderFormV3.Views.BaseCabinetFlyouts"
    xmlns:Converters="clr-namespace:CorlaneCabinetOrderFormV3.Converters"
    xmlns:appbehaviors="clr-namespace:CorlaneCabinetOrderFormV3.Behaviors">
    <local:FlyoutUserControlBase.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}"/>
        <Style TargetType="CheckBox" BasedOn="{StaticResource FlyoutCheckBox}"/>
        <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
    </local:FlyoutUserControlBase.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <TextBlock Text="Dimensions" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

            <!--===== STANDARD / DRAWER BASE =====-->
            <StackPanel Visibility="{Binding StdOrDrwBaseVisibility, Converter={StaticResource BoolToVisibilityConverter}}">
                <Label Content="Width" Margin="0,4,0,0"/>
                <TextBox x:Name="textWidthBase" Width="120" HorizontalAlignment="Left"
                         Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TextBoxGotFocus"
                         appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                           Visibility="{Binding (Validation.HasError), ElementName=textWidthBase, Converter={StaticResource BoolToVisibilityConverter}}"
                           Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textWidthBase, FallbackValue=''}"/>

                <Label Content="Height" Margin="0,8,0,0"/>
                <TextBox x:Name="textHeightBase" Width="120" HorizontalAlignment="Left"
                         Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TextBoxGotFocus"
                         appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                           Visibility="{Binding (Validation.HasError), ElementName=textHeightBase, Converter={StaticResource BoolToVisibilityConverter}}"
                           Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textHeightBase, FallbackValue=''}"/>

                <Label Content="Depth" Margin="0,8,0,0"/>
                <TextBox x:Name="textDepthBase" Width="120" HorizontalAlignment="Left"
                         Text="{Binding Depth, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TextBoxGotFocus"
                         appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                           Visibility="{Binding (Validation.HasError), ElementName=textDepthBase, Converter={StaticResource BoolToVisibilityConverter}}"
                           Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textDepthBase, FallbackValue=''}"/>
            </StackPanel>

            <!--===== CORNER 90° =====-->
            <StackPanel Visibility="{Binding Corner90Visibility, Converter={StaticResource BoolToVisibilityConverter}}">
                <Label Content="Left Front Width" Padding="0" Margin="0,4,0,0"/>
                <TextBox x:Name="textLeftFrontWidthBase" Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
                         Text="{Binding LeftFrontWidth, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TextBoxGotFocus" appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                           Visibility="{Binding (Validation.HasError), ElementName=textLeftFrontWidthBase, Converter={StaticResource BoolToVisibilityConverter}}"
                           Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textLeftFrontWidthBase, FallbackValue=''}"/>

                <Label Content="Right Front Width" Padding="0" Margin="0,8,0,0"/>
                <TextBox x:Name="textRightFrontWidthBase" Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
                         Text="{Binding RightFrontWidth, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TextBoxGotFocus" appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                           Visibility="{Binding (Validation.HasError), ElementName=textRightFrontWidthBase, Converter={StaticResource BoolToVisibilityConverter}}"
                           Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textRightFrontWidthBase, FallbackValue=''}"/>

                <Label Content="Left Depth" Padding="0" Margin="0,8,0,0"/>
                <TextBox x:Name="textLeftDepthBase" Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
                         Text="{Binding LeftDepth, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TextBoxGotFocus" appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                           Visibility="{Binding (Validation.HasError), ElementName=textLeftDepthBase, Converter={StaticResource BoolToVisibilityConverter}}"
                           Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textLeftDepthBase, FallbackValue=''}"/>

                <Label Content="Right Depth" Padding="0" Margin="0,8,0,0"/>
                <TextBox x:Name="textRightDepthBase" Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
                         Text="{Binding RightDepth, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TextBoxGotFocus" appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                           Visibility="{Binding (Validation.HasError), ElementName=textRightDepthBase, Converter={StaticResource BoolToVisibilityConverter}}"
                           Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textRightDepthBase, FallbackValue=''}"/>

                <Label Content="Left Back Width" Padding="0" Margin="0,8,0,0"/>
                <TextBox Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
                         Text="{Binding LeftBackWidth90}" IsReadOnly="True" IsEnabled="False"
                         appbehaviors:DimensionAutoFormat.IsEnabled="True"/>

                <Label Content="Right Back Width" Padding="0" Margin="0,8,0,0"/>
                <TextBox Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
                         Text="{Binding RightBackWidth90}" IsReadOnly="True" IsEnabled="False"
                         appbehaviors:DimensionAutoFormat.IsEnabled="True"/>

                <Label Content="Height" Padding="0" Margin="0,8,0,0"/>
                <TextBox x:Name="textHeightCornerBase" Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
                         Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TextBoxGotFocus" appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                           Visibility="{Binding (Validation.HasError), ElementName=textHeightCornerBase, Converter={StaticResource BoolToVisibilityConverter}}"
                           Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textHeightCornerBase, FallbackValue=''}"/>
            </StackPanel>

            <!--===== CORNER 45° =====-->
            <StackPanel Visibility="{Binding Corner45Visibility, Converter={StaticResource BoolToVisibilityConverter}}">
                <Label Content="Left Depth" Padding="0" Margin="0,4,0,0"/>
                <TextBox x:Name="textLeftDepth45Base" Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
                         Text="{Binding LeftDepth, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TextBoxGotFocus" appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                           Visibility="{Binding (Validation.HasError), ElementName=textLeftDepth45Base, Converter={StaticResource BoolToVisibilityConverter}}"
                           Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textLeftDepth45Base, FallbackValue=''}"/>

                <Label Content="Right Depth" Padding="0" Margin="0,8,0,0"/>
                <TextBox x:Name="textRightDepth45Base" Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
                         Text="{Binding RightDepth, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TextBoxGotFocus" appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                           Visibility="{Binding (Validation.HasError), ElementName=textRightDepth45Base, Converter={StaticResource BoolToVisibilityConverter}}"
                           Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textRightDepth45Base, FallbackValue=''}"/>

                <Label Content="Left Back Width" Padding="0" Margin="0,8,0,0"/>
                <TextBox x:Name="textLeftBackWidth45Base" Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
                         Text="{Binding LeftBackWidth, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TextBoxGotFocus" appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                           Visibility="{Binding (Validation.HasError), ElementName=textLeftBackWidth45Base, Converter={StaticResource BoolToVisibilityConverter}}"
                           Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textLeftBackWidth45Base, FallbackValue=''}"/>

                <Label Content="Right Back Width" Padding="0" Margin="0,8,0,0"/>
                <TextBox x:Name="textRightBackWidth45Base" Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
                         Text="{Binding RightBackWidth, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TextBoxGotFocus" appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                           Visibility="{Binding (Validation.HasError), ElementName=textRightBackWidth45Base, Converter={StaticResource BoolToVisibilityConverter}}"
                           Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textRightBackWidth45Base, FallbackValue=''}"/>

                <Label Content="Front Width" Padding="0" Margin="0,8,0,0"/>
                <TextBox Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
                         Text="{Binding FrontWidth}" IsReadOnly="True" IsEnabled="False"/>

                <Label Content="Height" Padding="0" Margin="0,8,0,0"/>
                <TextBox x:Name="textHeightCorner45Base" Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
                         Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TextBoxGotFocus" appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                           Visibility="{Binding (Validation.HasError), ElementName=textHeightCorner45Base, Converter={StaticResource BoolToVisibilityConverter}}"
                           Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textHeightCorner45Base, FallbackValue=''}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</local:FlyoutUserControlBase>