<local:FlyoutUserControlBase
    x:Class="CorlaneCabinetOrderFormV3.Views.UpperCabinetFlyouts.UpperCabinetStyleFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:CorlaneCabinetOrderFormV3.Views.BaseCabinetFlyouts"
    xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors">
    <local:FlyoutUserControlBase.Resources>
        <Style TargetType="ListBox" BasedOn="{StaticResource FlyoutListBox}"/>
    </local:FlyoutUserControlBase.Resources>
    <StackPanel>
        <TextBlock Text="Cabinet Style" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ListBox ItemsSource="{Binding TypeList}"
                 SelectedValue="{Binding Style, Mode=TwoWay}">
            <behaviors:Interaction.Triggers>
                <behaviors:EventTrigger EventName="SelectionChanged">
                    <behaviors:InvokeCommandAction Command="{Binding LoadDefaultsCommand}"/>
                </behaviors:EventTrigger>
            </behaviors:Interaction.Triggers>
        </ListBox>
    </StackPanel>
</local:FlyoutUserControlBase>