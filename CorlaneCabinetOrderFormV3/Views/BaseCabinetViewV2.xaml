                        <Label Content="Number of Drawers:" Padding="0" Margin="0,0,0,4"/>
                        <ComboBox Width="60" HorizontalAlignment="Left"
                                  ItemsSource="{Binding ListDrwCount, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}"
                                  SelectedItem="{Binding DrwCount}"/>

                        <!-- Everything below is visible only when drawers > 0 -->
                        <StackPanel Visibility="{Binding DrawersStackPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">

                            <!-- Grain Direction -->
                            <Label Content="Drawer Front Grain Direction:" Padding="0" Margin="0,10,0,4"/>
                            <ComboBox Width="120" HorizontalAlignment="Left"
                                      ItemsSource="{Binding ListGrainDirection}"
                                      SelectedItem="{Binding DrwFrontGrainDir}"/>

                            <!-- Drawer Style -->
                            <Label Content="Drawer Style:" Padding="0" Margin="0,8,0,4"
                                   Visibility="{Binding ListDrawerStyleVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <ComboBox Width="320" HorizontalAlignment="Left"
                                      ItemsSource="{Binding ListDrawerStyle}"
                                      SelectedValue="{Binding DrwStyle, UpdateSourceTrigger=PropertyChanged}"
                                      Visibility="{Binding ListDrawerStyleVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <Separator Margin="0,8,0,8"/>

                            <!--===== OPENING HEIGHTS =====-->
                            <TextBlock Text="Opening Heights" FontSize="18" FontWeight="SemiBold" Margin="0,10,0,6"/>

                            <!-- Opening 1 -->
                            <StackPanel Orientation="Horizontal" Visibility="{Binding Opening1Visible, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,6">
                                <TextBlock Text="Opening 1" VerticalAlignment="Center" FontWeight="SemiBold" Width="Auto" Margin="0,0,5,0"/>
                                <TextBox x:Name="textOpeningHeight1" Width="80" VerticalAlignment="Center"
                                         IsReadOnly="{Binding Opening1Disabled}"
                                         Text="{Binding OpeningHeight1, UpdateSourceTrigger=PropertyChanged}"
                                         GotFocus="TextBoxGotFocus"/>
                                <CheckBox Content="Supply Drawer Box" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwBoxOpening1}" IsEnabled="{Binding SinkCabinet, Converter={StaticResource BoolInverter}}"/>
                                <CheckBox Content="Drill Slide Holes" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding DrillSlideHolesOpening1}" IsEnabled="{Binding SinkCabinet, Converter={StaticResource BoolInverter}}"/>
                                <CheckBox Content="Include in Sizes List" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwBoxInListOpening1}" IsEnabled="{Binding SinkCabinet, Converter={StaticResource BoolInverter}}"/>
                            </StackPanel>

                            <!-- Opening 2 -->
                            <StackPanel Orientation="Horizontal" Visibility="{Binding Opening2Visible, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,6">
                                <TextBlock Text="Opening 2" VerticalAlignment="Center" FontWeight="SemiBold" Width="Auto" Margin="0,0,5,0"/>
                                <TextBox x:Name="textOpeningHeight2" Width="80" VerticalAlignment="Center"
                                         IsReadOnly="{Binding Opening2Disabled}"
                                         Text="{Binding OpeningHeight2, UpdateSourceTrigger=PropertyChanged}"
                                         GotFocus="TextBoxGotFocus"/>
                                <CheckBox Content="Supply Drawer Box" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwBoxOpening2}"/>
                                <CheckBox Content="Drill Slide Holes" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding DrillSlideHolesOpening2}"/>
                                <CheckBox Content="Include in Sizes List" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwBoxInListOpening2}"/>
                            </StackPanel>

                            <!-- Opening 3 -->
                            <StackPanel Orientation="Horizontal" Visibility="{Binding Opening3Visible, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,6">
                                <TextBlock Text="Opening 3" VerticalAlignment="Center" FontWeight="SemiBold" Width="Auto" Margin="0,0,5,0"/>
                                <TextBox x:Name="textOpeningHeight3" Width="80" VerticalAlignment="Center"
                                         IsReadOnly="{Binding Opening3Disabled}"
                                         Text="{Binding OpeningHeight3, UpdateSourceTrigger=PropertyChanged}"
                                         GotFocus="TextBoxGotFocus"/>
                                <CheckBox Content="Supply Drawer Box" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwBoxOpening3}"/>
                                <CheckBox Content="Drill Slide Holes" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding DrillSlideHolesOpening3}"/>
                                <CheckBox Content="Include in Sizes List" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwBoxInListOpening3}"/>
                            </StackPanel>

                            <!-- Opening 4 -->
                            <StackPanel Orientation="Horizontal" Visibility="{Binding Opening4Visible, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,6">
                                <TextBlock Text="Opening 4" VerticalAlignment="Center" FontWeight="SemiBold" Width="Auto" Margin="0,0,5,0"/>
                                <TextBox x:Name="textOpeningHeight4" Width="80" VerticalAlignment="Center"
                                         IsReadOnly="True"
                                         Text="{Binding OpeningHeight4, UpdateSourceTrigger=PropertyChanged}"
                                         GotFocus="TextBoxGotFocus"/>
                                <CheckBox Content="Supply Drawer Box" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwBoxOpening4}"/>
                                <CheckBox Content="Drill Slide Holes" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding DrillSlideHolesOpening4}"/>
                                <CheckBox Content="Include in Sizes List" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwBoxInListOpening4}"/>
                            </StackPanel>

                            <Separator Margin="0,8,0,8"/>

                            <!--===== DRAWER FRONT HEIGHTS =====-->
                            <StackPanel Visibility="{Binding GroupDrawerFrontHeightsVisibility, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="Drw. Front Heights" FontSize="18" FontWeight="SemiBold" Margin="0,10,0,4"/>

                                <!-- Front 1 -->
                                <StackPanel Orientation="Horizontal" Visibility="{Binding DrwFront1Visible, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,6">
                                    <TextBlock Text="Drw. Front 1" VerticalAlignment="Center" FontWeight="SemiBold" Width="Auto" Margin="0,0,5,0"/>
                                    <TextBox x:Name="textDrwFrontHeight1" Width="80" VerticalAlignment="Center"
                                             IsReadOnly="{Binding DrwFront1Disabled}"
                                             Text="{Binding DrwFrontHeight1Edit, UpdateSourceTrigger=PropertyChanged}"
                                             GotFocus="TextBoxGotFocus"/>
                                    <CheckBox Content="Supply Slab Drawer Front" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwFront1}"/>
                                    <CheckBox Content="Include Drawer Front in Sizes List" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwFrontInList1}"/>
                                </StackPanel>

                                <!-- Front 2 -->
                                <StackPanel Orientation="Horizontal" Visibility="{Binding DrwFront2Visible, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,6">
                                    <TextBlock Text="Drw. Front 2" VerticalAlignment="Center" FontWeight="SemiBold" Width="Auto" Margin="0,0,5,0"/>
                                    <TextBox x:Name="textDrwFrontHeight2" Width="80" VerticalAlignment="Center"
                                             IsReadOnly="{Binding DrwFront2Disabled}"
                                             Text="{Binding DrwFrontHeight2, UpdateSourceTrigger=PropertyChanged}"
                                             GotFocus="TextBoxGotFocus"/>
                                    <CheckBox Content="Supply Slab Drawer Front" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwFront2}"/>
                                    <CheckBox Content="Include Drawer Front in Sizes List" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwFrontInList2}"/>
                                </StackPanel>

                                <!-- Front 3 -->
                                <StackPanel Orientation="Horizontal" Visibility="{Binding DrwFront3Visible, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,6">
                                    <TextBlock Text="Drw. Front 3" VerticalAlignment="Center" FontWeight="SemiBold" Width="Auto" Margin="0,0,5,0"/>
                                    <TextBox x:Name="textDrwFrontHeight3" Width="80" VerticalAlignment="Center"
                                             IsReadOnly="{Binding DrwFront3Disabled}"
                                             Text="{Binding DrwFrontHeight3, UpdateSourceTrigger=PropertyChanged}"
                                             GotFocus="TextBoxGotFocus"/>
                                    <CheckBox Content="Supply Slab Drawer Front" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwFront3}"/>
                                    <CheckBox Content="Include Drawer Front in Sizes List" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwFrontInList3}"/>
                                </StackPanel>

                                <!-- Front 4 -->
                                <StackPanel Orientation="Horizontal" Visibility="{Binding DrwFront4Visible, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,0,0,6">
                                    <TextBlock Text="Drw. Front 4" VerticalAlignment="Center" FontWeight="SemiBold" Width="Auto" Margin="0,0,5,0"/>
                                    <TextBox x:Name="textDrwFrontHeight4" Width="80" VerticalAlignment="Center"
                                             IsReadOnly="True"
                                             Text="{Binding DrwFrontHeight4, UpdateSourceTrigger=PropertyChanged}"
                                             GotFocus="TextBoxGotFocus"/>
                                    <CheckBox Content="Supply Slab Drawer Front" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwFront4}"/>
                                    <CheckBox Content="Include Drawer Front in Sizes List" VerticalAlignment="Center" Margin="14,0,0,0" IsChecked="{Binding IncDrwFrontInList4}"/>
                                </StackPanel>

                                <Separator Margin="0,8,0,8"/>

                                <StackPanel Orientation="Vertical" Margin="0,4,0,4">
                                    <CheckBox Content="Equalize Bottom Drawer Fronts" Style="{StaticResource FlyoutCheckBox}" HorizontalAlignment="Left" Margin="8,0,0,10" IsTabStop="False"
                                                  IsChecked="{Binding EqualizeBottomDrwFronts}"/>
                                    <CheckBox Content="Equalize All Drawer Fronts" Style="{StaticResource FlyoutCheckBox}" HorizontalAlignment="Left" Margin="8,0,0,10" IsTabStop="False"
                                                  IsChecked="{Binding EqualizeAllDrwFronts}"/>
                                    <Button Content="Load Default Drawer Front Settings" Style="{StaticResource FlyoutButton}" HorizontalAlignment="Left" Margin="8,0,0,10" IsTabStop="False"
                                            Command="{Binding LoadDefaultDrwSettingsCommand}"/>
                                </StackPanel>

                            </StackPanel>

                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>

        <!--========== SHELVES & ROLLOUTS FLYOUT ==========-->
        <Border Grid.Column="1"
                ClipToBounds="True"
                Background="{DynamicResource ABrush.Tone2.Background.Static}"
                BorderBrush="{DynamicResource ABrush.Tone4.Border.Static}"
                BorderThickness="0,0,1,0"
                CornerRadius="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=btnShelves}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="350" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Border Width="350" HorizontalAlignment="Left" Padding="10">
                <Border.Resources>
                    <!-- Implicit styles scoped to this flyout panel -->
                    <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}"/>
                    <Style TargetType="CheckBox" BasedOn="{StaticResource FlyoutCheckBox}"/>
                    <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
                    <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
                </Border.Resources>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!--===== SHELVES =====-->
                        <TextBlock Text="Shelves" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <Label Content="Shelf Count:" Padding="0" Margin="0,0,0,4"/>
                        <ComboBox Width="80" HorizontalAlignment="Left"
                                  ItemsSource="{Binding ComboShelfCount}"
                                  SelectedItem="{Binding ShelfCount}"/>

                        <Label Content="Shelf Depth:" Padding="0" Margin="0,10,0,4"
                               Visibility="{Binding ShelfDepthVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <ComboBox Width="120" HorizontalAlignment="Left"
                                  ItemsSource="{Binding ListShelfDepth}"
                                  SelectedItem="{Binding ShelfDepth}"
                                  IsEnabled="{Binding ComboShelfDepthEnabled}"
                                  Visibility="{Binding ShelfDepthVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <CheckBox Content="Drill Shelf Holes" Margin="0,10,0,0"
                                  IsChecked="{Binding DrillShelfHoles}"/>

                        <!--===== ROLLOUTS =====-->
                        <StackPanel Visibility="{Binding GroupRolloutsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Separator Margin="0,14,0,10"/>

                            <TextBlock Text="Rollout Shelves" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

                            <Label Content="Number of Rollouts:" Padding="0" Margin="0,0,0,4"/>
                            <ComboBox Width="60" HorizontalAlignment="Left"
                                      ItemsSource="{Binding ListRolloutCount}"
                                      SelectedItem="{Binding RolloutCount}"/>

                            <CheckBox Content="Supply Rollouts With Cabinet" Margin="0,10,0,4"
                                      IsChecked="{Binding IncRollouts}"
                                      IsEnabled="{Binding IncRolloutsEnabled}"
                                      Visibility="{Binding IncRolloutsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <CheckBox Content="Include Rollouts In Sizes List" Margin="0,4,0,4"
                                      IsChecked="{Binding IncRolloutsInList}"
                                      IsEnabled="{Binding IncRolloutsInListEnabled}"
                                      Visibility="{Binding IncRolloutsInListVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <CheckBox Content="Drill Slide Holes For Rollouts" Margin="0,4,0,4"
                                      IsChecked="{Binding DrillSlideHolesForRollouts}"
                                      Visibility="{Binding DrillSlideHolesForRolloutsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <Label Content="Rollout Style:" Padding="0" Margin="0,8,0,4"
                                   Visibility="{Binding RolloutStyleVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <ComboBox Width="320" HorizontalAlignment="Left"
                                      ItemsSource="{Binding ListDrawerStyle}"
                                      SelectedValue="{Binding RolloutStyle, UpdateSourceTrigger=PropertyChanged}"
                                      Visibility="{Binding RolloutStyleVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>

        <!--========== REVEALS FLYOUT ==========-->
        <Border Grid.Column="1"
                ClipToBounds="True"
                Background="{DynamicResource ABrush.Tone2.Background.Static}"
                BorderBrush="{DynamicResource ABrush.Tone4.Border.Static}"
                BorderThickness="0,0,1,0"
                CornerRadius="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=btnReveals}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="220" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Border Width="220" HorizontalAlignment="Left" Padding="10">
                <Border.Resources>
                    <!-- Implicit styles scoped to this flyout panel -->
                    <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}"/>
                    <Style TargetType="CheckBox" BasedOn="{StaticResource FlyoutCheckBox}"/>
                    <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
                    <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
                </Border.Resources>
                <StackPanel>
                    <TextBlock Text="Reveals &amp; Gaps" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <!-- Left Reveal -->
                    <Label Content="Left Reveal" Padding="0" Margin="0,4,0,0"/>
                    <TextBox x:Name="textBaseDoorLeftReveal" Width="80" HorizontalAlignment="Left" Margin="0,4,0,0"
                             Text="{Binding LeftReveal, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="TextBoxGotFocus"
                             appbehaviors:DimensionAutoFormat.IsEnabled="True"/>

                    <!-- Right Reveal -->
                    <Label Content="Right Reveal" Padding="0" Margin="0,8,0,0"/>
                    <TextBox x:Name="textBaseDoorRightReveal" Width="80" HorizontalAlignment="Left" Margin="0,4,0,0"
                             Text="{Binding RightReveal, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="TextBoxGotFocus"
                             appbehaviors:DimensionAutoFormat.IsEnabled="True"/>

                    <!-- Top Reveal -->
                    <Label Content="Top Reveal" Padding="0" Margin="0,8,0,0"/>
                    <TextBox x:Name="textBaseDoorTopReveal" Width="80" HorizontalAlignment="Left" Margin="0,4,0,0"
                             Text="{Binding TopReveal, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="TextBoxGotFocus"
                             appbehaviors:DimensionAutoFormat.IsEnabled="True"/>

                    <!-- Bottom Reveal -->
                    <Label Content="Bottom Reveal" Padding="0" Margin="0,8,0,0"/>
                    <TextBox x:Name="textBaseDoorBottomReveal" Width="80" HorizontalAlignment="Left" Margin="0,4,0,0"
                             Text="{Binding BottomReveal, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="TextBoxGotFocus"
                             appbehaviors:DimensionAutoFormat.IsEnabled="True"/>

                    <Separator Margin="0,12,0,8"/>

                    <!-- Door/Drw. Front Gaps -->
                    <Label Content="Door/Drw. Front Gaps" Padding="0" Margin="0,0,0,0"/>
                    <TextBox x:Name="textBaseDoorGaps" Width="80" HorizontalAlignment="Left" Margin="0,4,0,0"
                             Text="{Binding GapWidth, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="TextBoxGotFocus"
                             appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                </StackPanel>
            </Border>
        </Border>

        <!--========== MAIN CONTENT AREA ==========-->
        <!--========== MAIN CONTENT AREA ==========-->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 3D viewport is placed here programmatically by MainWindow -->
            <Border x:Name="ViewportHost" Grid.Row="0"/>
            
            <!--===== BOTTOM ACTION PANEL =====-->
            <Border Grid.Row="1"
                    Background="{DynamicResource ABrush.Tone2.Background.Static}"
                    BorderBrush="{DynamicResource ABrush.Tone4.Border.Static}"
                    BorderThickness="0,1,0,0"
                    Padding="16,12"
                    CornerRadius="10,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!--== LEFT: Load Defaults ==-->
                    <Button Grid.Column="0" Content="Load Defaults" FontSize="16" Padding="10,4"
                            VerticalAlignment="Center"
                            Command="{Binding LoadDefaultsCommand}"/>

                    <!--== CENTER: Special instructions ==-->
                    <StackPanel Grid.Column="1" Margin="24,0">
                        <TextBlock Text="Special Instructions / Notes" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="textBaseCabNotes" MinHeight="100" MaxHeight="100"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 FontSize="14"
                                 Text="{Binding Notes}"/>
                    </StackPanel>

                    <!--== RIGHT: Qty / Name / Add / Update ==-->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
                            <TextBlock Text="Qty:" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="textQty" Width="50" FontSize="16" VerticalAlignment="Center"
                                     Text="{Binding Qty, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource StringToIntConverter}}"
                                     GotFocus="TextBoxGotFocus"/>
                        </StackPanel>
                        <TextBlock FontSize="12" Foreground="Red" HorizontalAlignment="Right" Margin="0,0,0,4"
                                   Visibility="{Binding (Validation.HasError), ElementName=textQty, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textQty, FallbackValue=''}"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                            <TextBlock Text="Name:" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="textName" Width="150" FontSize="16" VerticalAlignment="Center"
                                     Text="{Binding Name}" GotFocus="TextBoxGotFocus"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="buttonAdd" Content="Add to List" FontSize="16" Padding="12,6" Margin="0,0,8,0"
                                    IsEnabled="{Binding HasErrors, Converter={StaticResource BoolInverter}}"
                                    Command="{Binding AddCabinetCommand}"/>
                            <Button x:Name="buttonUpdate" Content="Update in List" FontSize="16" Padding="12,6"
                                    IsEnabled="{Binding HasErrors, Converter={StaticResource BoolInverter}}"
                                    Command="{Binding UpdateCabinetCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>