<UserControl x:Class="CorlaneCabinetOrderFormV3.Views.BaseCabinetViewV2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CorlaneCabinetOrderFormV3.Views"
             xmlns:viewmodels="clr-namespace:CorlaneCabinetOrderFormV3.ViewModels"    
             xmlns:Converters="clr-namespace:CorlaneCabinetOrderFormV3.Converters"
             xmlns:Models="clr-namespace:CorlaneCabinetOrderFormV3.Models"
             xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:appbehaviors="clr-namespace:CorlaneCabinetOrderFormV3.Behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="960" d:DesignWidth="1000"
             d:Background="{DynamicResource ABrush.Tone8.Background.Static}"
             Background="{DynamicResource ABrush.Tone1.Background.Static}"
             >
    <!-- Design-time DataContext (so intellisense will work) -->
    <d:UserControl.DataContext>
        <viewmodels:BaseCabinetViewModel/>
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Converters:BoolInverter x:Key="BoolInverter"/>
        <Converters:StringToIntConverter x:Key="StringToIntConverter"/>

        <!-- Flyout-wide typography & spacing defaults -->
        <Style TargetType="TextBox" x:Key="FlyoutTextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="4,3"/>
        </Style>
        <Style TargetType="CheckBox" x:Key="FlyoutCheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>
        <Style TargetType="Label" x:Key="FlyoutLabel" BasedOn="{StaticResource {x:Type Label}}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style TargetType="ComboBox" x:Key="FlyoutComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style TargetType="ToggleButton" x:Key="FlyoutToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="6,3"/>
        </Style>
        <Style TargetType="Button" x:Key="FlyoutButton" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="6,3"/>
        </Style>
        <Style TargetType="ListBox" x:Key="FlyoutListBox" BasedOn="{StaticResource {x:Type ListBox}}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="6,3"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <!-- Vertical tab strip -->
            <ColumnDefinition Width="Auto"/>
            <!-- Flyout panel (animated width) -->
            <ColumnDefinition Width="*"/>
            <!-- Main content area -->
        </Grid.ColumnDefinitions>

        <!--========== VERTICAL TAB STRIP ==========-->
        <StackPanel Grid.Column="0" VerticalAlignment="Top"
                    Background="{DynamicResource ABrush.Tone3.Background.Static}">

            <ToggleButton x:Name="btnCabinetType" Padding="8,16" Margin="10">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Checked">
                        <behaviors:ChangePropertyAction TargetName="btnDimensions" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnSpecies" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnToekick" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnTopType" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnBackThickness" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDoors" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDrawers" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnShelves" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnReveals" PropertyName="IsChecked" Value="False"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <TextBlock Text="Cabinet Type" FontSize="14"/>
            </ToggleButton>

            <ToggleButton x:Name="btnDimensions" Padding="8,16" Margin="10">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Checked">
                        <behaviors:ChangePropertyAction TargetName="btnCabinetType" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnSpecies" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnToekick" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnTopType" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnBackThickness" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDoors" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDrawers" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnShelves" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnReveals" PropertyName="IsChecked" Value="False"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <TextBlock Text="Dimensions" FontSize="14"/>
            </ToggleButton>

            <ToggleButton x:Name="btnSpecies" Padding="8,16" Margin="10">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Checked">
                        <behaviors:ChangePropertyAction TargetName="btnCabinetType" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDimensions" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnToekick" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnTopType" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnBackThickness" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDoors" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDrawers" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnShelves" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnReveals" PropertyName="IsChecked" Value="False"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <TextBlock Text="Species" FontSize="14"/>
            </ToggleButton>

            <ToggleButton x:Name="btnToekick" Padding="8,16" Margin="10">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Checked">
                        <behaviors:ChangePropertyAction TargetName="btnCabinetType" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDimensions" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnSpecies" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnTopType" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnBackThickness" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDoors" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDrawers" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnShelves" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnReveals" PropertyName="IsChecked" Value="False"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <TextBlock Text="Toekick" FontSize="14"/>
            </ToggleButton>

            <ToggleButton x:Name="btnTopType" Padding="8,16" Margin="10"
                          Visibility="{Binding GroupCabinetTopTypeVisibility, Converter={StaticResource BoolToVisibilityConverter}}">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Checked">
                        <behaviors:ChangePropertyAction TargetName="btnCabinetType" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDimensions" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnSpecies" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnToekick" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnBackThickness" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDoors" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDrawers" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnShelves" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnReveals" PropertyName="IsChecked" Value="False"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <TextBlock Text="Top Type" FontSize="14"/>
            </ToggleButton>

            <ToggleButton x:Name="btnBackThickness" Padding="8,16" Margin="10"
                          Visibility="{Binding BackThicknessVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Checked">
                        <behaviors:ChangePropertyAction TargetName="btnCabinetType" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDimensions" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnSpecies" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnToekick" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnTopType" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDoors" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDrawers" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnShelves" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnReveals" PropertyName="IsChecked" Value="False"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <TextBlock Text="Back Thickness" FontSize="14"/>
            </ToggleButton>

            <ToggleButton x:Name="btnDoors" Padding="8,16" Margin="10"
                          Visibility="{Binding GroupDoorsVisibility, Converter={StaticResource BoolToVisibilityConverter}}">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Checked">
                        <behaviors:ChangePropertyAction TargetName="btnCabinetType" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDimensions" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnSpecies" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnToekick" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnTopType" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnBackThickness" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDrawers" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnShelves" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnReveals" PropertyName="IsChecked" Value="False"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <TextBlock Text="Doors" FontSize="14"/>
            </ToggleButton>

            <ToggleButton x:Name="btnDrawers" Padding="8,16" Margin="10"
                          Visibility="{Binding GroupDrawersVisibility, Converter={StaticResource BoolToVisibilityConverter}}">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Checked">
                        <behaviors:ChangePropertyAction TargetName="btnCabinetType" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDimensions" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnSpecies" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnToekick" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnTopType" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnBackThickness" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDoors" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnShelves" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnReveals" PropertyName="IsChecked" Value="False"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <TextBlock Text="Drawers" FontSize="14"/>
            </ToggleButton>

            <ToggleButton x:Name="btnShelves" Padding="8,16" Margin="10"
                          Visibility="{Binding GroupShelvesVisibility, Converter={StaticResource BoolToVisibilityConverter}}">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Checked">
                        <behaviors:ChangePropertyAction TargetName="btnCabinetType" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDimensions" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnSpecies" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnToekick" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnTopType" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnBackThickness" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDoors" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDrawers" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnReveals" PropertyName="IsChecked" Value="False"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <TextBlock Text="Shelves" FontSize="14"/>
            </ToggleButton>

            <ToggleButton x:Name="btnReveals" Padding="8,16" Margin="10">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Checked">
                        <behaviors:ChangePropertyAction TargetName="btnCabinetType" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDimensions" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnSpecies" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnToekick" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnTopType" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnBackThickness" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDoors" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDrawers" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnShelves" PropertyName="IsChecked" Value="False"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <TextBlock Text="Reveals" FontSize="14"/>
            </ToggleButton>
        </StackPanel>

        <!--========== CABINET TYPE FLYOUT ==========-->
        <Border Grid.Column="1"
                ClipToBounds="True"
                Background="{DynamicResource ABrush.Tone2.Background.Static}"
                BorderBrush="{DynamicResource ABrush.Tone4.Border.Static}"
                BorderThickness="0,0,1,0"
                CornerRadius="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=btnCabinetType}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="220" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Border Width="220" HorizontalAlignment="Left" Padding="10">
                <Border.Resources>
                    <!-- Implicit styles scoped to this flyout panel -->
                    <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}"/>
                    <Style TargetType="CheckBox" BasedOn="{StaticResource FlyoutCheckBox}"/>
                    <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
                    <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
                    <Style TargetType="ListBox" BasedOn="{StaticResource FlyoutListBox}"/>
                </Border.Resources>
                <StackPanel>
                    <TextBlock Text="Cabinet Type" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ListBox ItemsSource="{Binding TypeList}"
                             SelectedValue="{Binding Style, Mode=TwoWay}">
                        <behaviors:Interaction.Triggers>
                            <behaviors:EventTrigger EventName="SelectionChanged">
                                <behaviors:InvokeCommandAction Command="{Binding LoadDefaultsCommand}"/>
                            </behaviors:EventTrigger>
                        </behaviors:Interaction.Triggers>
                    </ListBox>

                    <Separator Margin="0,10,0,8"/>

                    <CheckBox Content="Sink Cabinet"
                              IsChecked="{Binding SinkCabinet, UpdateSourceTrigger=PropertyChanged}"
                              IsEnabled="{Binding SinkCabinetEnabled}"/>
                    <CheckBox Content="Trash Drawer"
                              IsChecked="{Binding TrashDrawer}"
                              IsEnabled="{Binding TrashDrawerEnabled}"/>
                    <CheckBox Content="Supply Drw Box" Margin="16,5,0,5"
                              IsChecked="{Binding IncTrashDrwBox}"
                              IsEnabled="{Binding TrashDrawer}"/>
                </StackPanel>
            </Border>
        </Border>

        <!--========== DIMENSIONS FLYOUT ==========-->
        <Border Grid.Column="1"
                ClipToBounds="True"
                Background="{DynamicResource ABrush.Tone2.Background.Static}"
                BorderBrush="{DynamicResource ABrush.Tone4.Border.Static}"
                BorderThickness="0,0,1,0"
                CornerRadius="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=btnDimensions}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="220" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Border Width="220" HorizontalAlignment="Left" Padding="10">
                <Border.Resources>
                    <!-- Implicit styles scoped to this flyout panel -->
                    <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}"/>
                    <Style TargetType="CheckBox" BasedOn="{StaticResource FlyoutCheckBox}"/>
                    <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
                    <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
                </Border.Resources>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="Dimensions" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <!--===== STANDARD / DRAWER BASE =====-->
                        <StackPanel Visibility="{Binding StdOrDrwBaseVisibility, Converter={StaticResource BoolToVisibilityConverter}}">
                            <!-- Width -->
                            <Label Content="Width" Margin="0,4,0,0"/>
                            <TextBox x:Name="textWidthBase" Width="120" HorizontalAlignment="Left"
                                     Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}"
                                     GotFocus="TextBoxGotFocus"
                                     appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                            <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                                       Visibility="{Binding (Validation.HasError), ElementName=textWidthBase, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textWidthBase, FallbackValue=''}"/>

                            <!-- Height -->
                            <Label Content="Height" Margin="0,8,0,0"/>
                            <TextBox x:Name="textHeightBase" Width="120" HorizontalAlignment="Left"
                                     Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}"
                                     GotFocus="TextBoxGotFocus"
                                     appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                            <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                                       Visibility="{Binding (Validation.HasError), ElementName=textHeightBase, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textHeightBase, FallbackValue=''}"/>

                            <!-- Depth -->
                            <Label Content="Depth" Margin="0,8,0,0"/>
                            <TextBox x:Name="textDepthBase" Width="120" HorizontalAlignment="Left"
                                     Text="{Binding Depth, UpdateSourceTrigger=PropertyChanged}"
                                     GotFocus="TextBoxGotFocus"
                                     appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                            <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                                       Visibility="{Binding (Validation.HasError), ElementName=textDepthBase, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textDepthBase, FallbackValue=''}"/>
                        </StackPanel>

                        <!--===== CORNER 90° =====-->
                        <StackPanel Visibility="{Binding Corner90Visibility, Converter={StaticResource BoolToVisibilityConverter}}">
                            <!-- Left Front Width -->
                            <Label Content="Left Front Width" Padding="0" Margin="0,4,0,0"/>
                            <TextBox x:Name="textLeftFrontWidthBase" Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
                                     Text="{Binding LeftFrontWidth, UpdateSourceTrigger=PropertyChanged}"
                                     GotFocus="TextBoxGotFocus"
                                     appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                            <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                                       Visibility="{Binding (Validation.HasError), ElementName=textLeftFrontWidthBase, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textLeftFrontWidthBase, FallbackValue=''}"/>

                            <!-- Right Front Width -->
                            <Label Content="Right Front Width" Padding="0" Margin="0,8,0,0"/>
                            <TextBox x:Name="textRightFrontWidthBase" Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
                                     Text="{Binding RightFrontWidth, UpdateSourceTrigger=PropertyChanged}"
                                     GotFocus="TextBoxGotFocus"
                                     appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                            <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                                       Visibility="{Binding (Validation.HasError), ElementName=textRightFrontWidthBase, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textRightFrontWidthBase, FallbackValue=''}"/>

                            <!-- Left Depth -->
                            <Label Content="Left Depth" Padding="0" Margin="0,8,0,0"/>
                            <TextBox x:Name="textLeftDepthBase" Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
                                     Text="{Binding LeftDepth, UpdateSourceTrigger=PropertyChanged}"
                                     GotFocus="TextBoxGotFocus"
                                     appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                            <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                                       Visibility="{Binding (Validation.HasError), ElementName=textLeftDepthBase, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textLeftDepthBase, FallbackValue=''}"/>

                            <!-- Right Depth -->
                            <Label Content="Right Depth" Padding="0" Margin="0,8,0,0"/>
                            <TextBox x:Name="textRightDepthBase" Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
                                     Text="{Binding RightDepth, UpdateSourceTrigger=PropertyChanged}"
                                     GotFocus="TextBoxGotFocus"
                                     appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                            <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                                       Visibility="{Binding (Validation.HasError), ElementName=textRightDepthBase, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textRightDepthBase, FallbackValue=''}"/>

                            <!-- Left Back Width (read-only) -->
                            <Label Content="Left Back Width" Padding="0" Margin="0,8,0,0"/>
                            <TextBox x:Name="textLeftBackWidthBase" Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
                                     Text="{Binding LeftBackWidth90}" IsReadOnly="True" IsEnabled="False"
                                     appbehaviors:DimensionAutoFormat.IsEnabled="True"/>

                            <!-- Right Back Width (read-only) -->
                            <Label Content="Right Back Width" Padding="0" Margin="0,8,0,0"/>
                            <TextBox x:Name="textRightBackWidthBase" Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"
