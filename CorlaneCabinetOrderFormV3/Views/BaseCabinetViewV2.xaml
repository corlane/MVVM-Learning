                <StackPanel>
                    <TextBlock Text="Back Thickness" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ListBox ItemsSource="{Binding ListBackThickness}"
                             SelectedItem="{Binding BackThickness}"/>
                </StackPanel>
            </Border>
        </Border>

        <!--========== DOORS FLYOUT ==========-->
        <Border Grid.Column="1"
                ClipToBounds="True"
                Background="{DynamicResource ABrush.Tone2.Background.Static}"
                BorderBrush="{DynamicResource ABrush.Tone4.Border.Static}"
                BorderThickness="0,0,1,0"
                CornerRadius="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=btnDoors}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="320" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Border Width="320" HorizontalAlignment="Left" Padding="10">
                <Border.Resources>
                    <!-- Implicit styles scoped to this flyout panel -->
                    <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}"/>
                    <Style TargetType="CheckBox" BasedOn="{StaticResource FlyoutCheckBox}"/>
                    <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
                    <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
                </Border.Resources>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="Doors" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <!-- Door Count -->
                        <Label Content="No. of Doors:" Padding="0" Margin="0,0,0,4"/>
                        <ComboBox Width="60" HorizontalAlignment="Left"
                                  ItemsSource="{Binding ListDoorCount, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}"
                                  SelectedItem="{Binding DoorCount}"/>

                        <!-- Door Grain Direction -->
                        <Label Content="Door Grain Direction:" Padding="0" Margin="0,10,0,4"
                               Visibility="{Binding DoorGrainDirVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <ComboBox Width="120" HorizontalAlignment="Left"
                                  ItemsSource="{Binding ListGrainDirection}"
                                  SelectedItem="{Binding DoorGrainDir}"
                                  Visibility="{Binding DoorGrainDirVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <Separator Margin="0,10,0,6"/>

                        <!-- Options -->
                        <CheckBox Content="Supply Slab Doors With Cabinet" Margin="0,4,0,4"
                                  IsChecked="{Binding IncDoors}"
                                  Visibility="{Binding SupplySlabDoorsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <CheckBox Content="Include Doors In Sizes List" Margin="0,4,0,4"
                                  IsChecked="{Binding IncDoorsInList}"
                                  Visibility="{Binding IncDoorsInListVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <CheckBox Content="Drill Hinge Plate Mounting Holes" Margin="0,4,0,0"
                                  IsChecked="{Binding DrillHingeHoles}"
                                  Visibility="{Binding DrillHingeHolesVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>

        <!--========== DRAWERS FLYOUT ==========-->
        <Border Grid.Column="1"
                ClipToBounds="True"
                Background="{DynamicResource ABrush.Tone2.Background.Static}"
                BorderBrush="{DynamicResource ABrush.Tone4.Border.Static}"
                BorderThickness="0,0,1,0"
                CornerRadius="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=btnDrawers}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="740" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Border Width="740" HorizontalAlignment="Left" Padding="10">
                <Border.Resources>
                    <!-- Implicit styles scoped to this flyout panel -->
                    <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}"/>
                    <Style TargetType="CheckBox" BasedOn="{StaticResource FlyoutCheckBox}"/>
                    <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
                    <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
