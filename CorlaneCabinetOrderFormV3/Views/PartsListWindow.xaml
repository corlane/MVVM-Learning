<Window x:Class="CorlaneCabinetOrderFormV3.Views.PartsListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Job Parts List"
        Width="1300" Height="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ABrush.Tone1.Background.Static}"
		FontSize="16">

    <Window.Resources>
        <CollectionViewSource x:Key="PartsView" Source="{Binding}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="CabinetLabel"/>
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Job Parts List"
                   FontSize="18"
                   FontWeight="SemiBold"/>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Source={StaticResource PartsView}}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="{DynamicResource ABrush.Tone8.Background.Static}">

            <DataGrid.GroupStyle>
                <GroupStyle>
                    <GroupStyle.ContainerStyle>
                        <Style TargetType="{x:Type GroupItem}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                        <Expander IsExpanded="True">
                                            <Expander.Header>
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="Bold"
                                                           FontSize="14"
                                                           Margin="0,6,0,2"/>
                                            </Expander.Header>
                                            <ItemsPresenter/>
                                        </Expander>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.ContainerStyle>
                </GroupStyle>
            </DataGrid.GroupStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Part" Binding="{Binding PartName}" Width="200"/>
                <DataGridTextColumn Header="Qty" Binding="{Binding Qty}" Width="40"/>
                <DataGridTextColumn Header="Species" Binding="{Binding Species}" Width="130"/>
                <DataGridTextColumn Header="Length (∥ grain)" Binding="{Binding Length}" Width="90"/>
                <DataGridTextColumn Header="Width (⊥ grain)" Binding="{Binding Width}" Width="90"/>
                <DataGridTextColumn Header="Thickness" Binding="{Binding Thickness}" Width="70"/>
                <DataGridTextColumn Header="EB Species" Binding="{Binding EdgeBandSpecies}" Width="130"/>
                <DataGridTextColumn Header="EB Length" Binding="{Binding EdgeBandLength}" Width="80"/>
                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Copy to Clipboard"
                    Padding="12,6"
                    Margin="0,0,8,0"
                    Click="CopyToClipboard_Click"/>
            <Button Content="Close"
                    Padding="12,6"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>