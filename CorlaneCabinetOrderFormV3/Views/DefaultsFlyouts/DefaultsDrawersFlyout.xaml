<local:FlyoutUserControlBase
    x:Class="CorlaneCabinetOrderFormV3.Views.DefaultsFlyouts.DefaultsDrawersFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:CorlaneCabinetOrderFormV3.Views.BaseCabinetFlyouts">
    <local:FlyoutUserControlBase.Resources>
        <Style TargetType="CheckBox" BasedOn="{StaticResource FlyoutCheckBox}"/>
        <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
    </local:FlyoutUserControlBase.Resources>
    <StackPanel>
        <TextBlock Text="Drawers" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <StackPanel Orientation="Horizontal">
            <StackPanel Margin="0,0,20,0">
                <Label Content="Std. Base Drw Count" Margin="0,4,0,0"/>
                <ComboBox ItemsSource="{Binding ListStdDrwCount}" SelectedValue="{Binding DefaultStdDrawerCount}"
                          Width="80" HorizontalAlignment="Left" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel>
                <Label Content="Drawer Base Drw Count" Margin="0,4,0,0"/>
                <ComboBox ItemsSource="{Binding ListDrwStackDrwCount}" SelectedValue="{Binding DefaultDrawerStackDrawerCount}"
                          Width="80" HorizontalAlignment="Left" Margin="0,4,0,0"/>
            </StackPanel>
        </StackPanel>

        <Separator Margin="0,12,0,8"/>

        <CheckBox Content="Drill Drawer Slide Holes In Cabinet" IsChecked="{Binding DefaultDrillSlideHoles}"/>
        <CheckBox Content="Include Drawer Boxes With Cabinet" IsChecked="{Binding DefaultIncDrwBoxes}"/>
        <CheckBox Content="Include Drawer Boxes in Drw Box Size List" IsChecked="{Binding DefaultIncDrwBoxesInList}"/>

        <Separator Margin="0,8,0,8"/>

        <Label Content="Drawer Style" Margin="0,0,0,0"/>
        <ComboBox ItemsSource="{Binding ListDrawerStyle}" SelectedValue="{Binding DefaultDrwStyle}" Margin="0,4,0,0"/>
    </StackPanel>
</local:FlyoutUserControlBase>