<local:FlyoutUserControlBase
    x:Class="CorlaneCabinetOrderFormV3.Views.DefaultsFlyouts.DefaultsThicknessFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:CorlaneCabinetOrderFormV3.Views.BaseCabinetFlyouts">
    <local:FlyoutUserControlBase.Resources>
        <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
    </local:FlyoutUserControlBase.Resources>
    <StackPanel>
        <TextBlock Text="Thickness" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <Label Content="Base Back Thickness" Margin="0,4,0,0"/>
        <ComboBox ItemsSource="{Binding ListBackThickness}" SelectedItem="{Binding DefaultBaseBackThickness}"
                  Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"/>

        <Label Content="Upper Back Thickness" Margin="0,12,0,0"/>
        <ComboBox ItemsSource="{Binding ListBackThickness}" SelectedItem="{Binding DefaultUpperBackThickness}"
                  Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"/>

        <Separator Margin="0,16,0,12"/>

        <Label Content="Panel Thickness" Margin="0,0,0,0"/>
        <ComboBox ItemsSource="{Binding ListBackThickness}" SelectedItem="{Binding DefaultPanelThickness}"
                  Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"/>

        <Separator Margin="0,16,0,12"/>

        <Label Content="Base Cabinet Top Type" Margin="0,0,0,0"/>
        <ComboBox ItemsSource="{Binding ListTopType}" SelectedItem="{Binding DefaultTopType}"
                  Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"/>
    </StackPanel>
</local:FlyoutUserControlBase>