<local:FlyoutUserControlBase
    x:Class="CorlaneCabinetOrderFormV3.Views.DefaultsFlyouts.DefaultsDoorsFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:CorlaneCabinetOrderFormV3.Views.BaseCabinetFlyouts">
    <local:FlyoutUserControlBase.Resources>
        <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}"/>
        <Style TargetType="CheckBox" BasedOn="{StaticResource FlyoutCheckBox}"/>
        <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
        <Style TargetType="ToggleButton" BasedOn="{StaticResource FlyoutToggleButton}"/>
    </local:FlyoutUserControlBase.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <TextBlock Text="Doors &amp; Drawer Fronts" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

            <CheckBox Content="Drill Hinge Plate Mounting Holes" IsChecked="{Binding DefaultDrillHingeHoles}"/>
            <CheckBox Content="Include Doors In Door Sizes List" IsChecked="{Binding DefaultIncDoorsInList}"/>
            <CheckBox Content="Include Slab Doors With Cabinet" IsChecked="{Binding DefaultIncDoors}"/>
            <CheckBox Content="Include Drw Fronts In Door Sizes List" IsChecked="{Binding DefaultIncDrwFrontsInList}"/>
            <CheckBox Content="Include Slab Drw Fronts With Cabinet" IsChecked="{Binding DefaultIncDrwFronts}"/>

            <Separator Margin="0,10,0,8"/>

            <Label Content="Door Grain Direction" Margin="0,0,0,0"/>
            <ComboBox ItemsSource="{Binding ListGrainDirection}" SelectedItem="{Binding DefaultDoorGrainDir}"
                      Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"/>

            <Label Content="Drawer Front Grain Direction" Margin="0,10,0,0"/>
            <ComboBox ItemsSource="{Binding ListGrainDirection}" SelectedItem="{Binding DefaultDrwGrainDir}"
                      Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"/>

            <Separator Margin="0,10,0,8"/>

            <CheckBox Content="Apply Matching Edgebanding To Doors &amp; Drawer Fronts" Margin="0,10,0,4"
                      IsChecked="{Binding DefaultEdgebandDoorsAndDrawers}"/>

            <Separator Margin="0,12,0,8"/>

            <TextBlock Text="Default Drw. Front Heights" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,6"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Top" Margin="0,2,0,0"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         x:Name="textDefaultDrwFront1Height"
                         Width="70" HorizontalAlignment="Left" Margin="0,2,0,0"
                         Text="{Binding DefaultDrwFrontHeight1, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TextBoxGotFocus">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DefaultEqualizeAllDrwFronts}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Label Grid.Row="1" Grid.Column="0" Content="Second" Margin="0,6,0,0"/>
                <TextBox Grid.Row="1" Grid.Column="1"
                         x:Name="textDefaultDrwFront2Height"
                         Width="70" HorizontalAlignment="Left" Margin="0,6,0,0"
                         Text="{Binding DefaultDrwFrontHeight2, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TextBoxGotFocus">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DefaultEqualizeBottomDrwFronts}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DefaultEqualizeAllDrwFronts}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Label Grid.Row="2" Grid.Column="0" Content="Third" Margin="0,6,0,0"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                         x:Name="textDefaultDrwFront3Height"
                         Width="70" HorizontalAlignment="Left" Margin="0,6,0,0"
                         Text="{Binding DefaultDrwFrontHeight3, UpdateSourceTrigger=PropertyChanged}"
                         GotFocus="TextBoxGotFocus">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DefaultEqualizeBottomDrwFronts}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DefaultEqualizeAllDrwFronts}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                          Content="Equalize Bottom Drw. Fronts"
                          IsChecked="{Binding DefaultEqualizeBottomDrwFronts}" Margin="0,8,0,0"/>
                <CheckBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                          Content="Equalize All Drw. Fronts"
                          IsChecked="{Binding DefaultEqualizeAllDrwFronts}" Margin="0,6,0,0"/>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</local:FlyoutUserControlBase>