<local:FlyoutUserControlBase
    x:Class="CorlaneCabinetOrderFormV3.Views.DefaultsFlyouts.DefaultsShelvesFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:CorlaneCabinetOrderFormV3.Views.BaseCabinetFlyouts">
    <local:FlyoutUserControlBase.Resources>
        <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}"/>
        <Style TargetType="CheckBox" BasedOn="{StaticResource FlyoutCheckBox}"/>
        <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
    </local:FlyoutUserControlBase.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <TextBlock Text="Shelves" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

            <CheckBox Content="Drill Shelf Holes" IsChecked="{Binding DefaultDrillShelfHoles}" Margin="0,15,0,0"/>

            <Separator Margin="0,14,0,10"/>

            <Label Content="Base Shelf Count" Margin="0,4,0,0"/>
            <ComboBox ItemsSource="{Binding ListShelfCount}" SelectedValue="{Binding DefaultShelfCount}"
                      Width="80" HorizontalAlignment="Left" Margin="0,4,0,0"/>

            <Label Content="Base Shelf Depth" Margin="0,8,0,0"/>
            <ComboBox ItemsSource="{Binding ListShelfDepth}" SelectedItem="{Binding DefaultShelfDepth}"
                      Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"/>
            <TextBlock Text="Shelf Depth only applies to Base cabinet types." FontSize="12"
                       TextWrapping="Wrap" Margin="0,4,0,0" Foreground="Gray"/>

            <Separator Margin="0,10,0,8"/>

            <Label Content="Upper Shelf Count" Margin="0,0,0,0"/>
            <ComboBox ItemsSource="{Binding ListShelfCount}" SelectedValue="{Binding DefaultUpperShelfCount}"
                      Width="80" HorizontalAlignment="Left" Margin="0,4,0,0"/>

            <Separator Margin="0,14,0,12"/>

            <TextBlock Text="Toekick" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

            <CheckBox Content="Has Toekick" IsChecked="{Binding DefaultHasTK}"/>

            <Label Content="Toekick Height" Margin="0,8,0,0"/>
            <TextBox x:Name="textDefaultTKHeight" Width="70" HorizontalAlignment="Left" Margin="0,4,0,0"
                     Text="{Binding DefaultTKHeight}" GotFocus="TextBoxGotFocus"/>

            <Label Content="Toekick Depth" Margin="0,8,0,0"/>
            <TextBox x:Name="textDefaultTKDepth" Width="70" HorizontalAlignment="Left" Margin="0,4,0,0"
                     Text="{Binding DefaultTKDepth}" GotFocus="TextBoxGotFocus"/>
        </StackPanel>
    </ScrollViewer>
</local:FlyoutUserControlBase>