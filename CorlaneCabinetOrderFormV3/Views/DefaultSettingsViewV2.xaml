<UserControl x:Class="CorlaneCabinetOrderFormV3.Views.DefaultSettingsViewV2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CorlaneCabinetOrderFormV3.Views"
             xmlns:viewmodels="clr-namespace:CorlaneCabinetOrderFormV3.ViewModels"    
             xmlns:Converters="clr-namespace:CorlaneCabinetOrderFormV3.Converters"
             xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="960" d:DesignWidth="1000"
             d:Background="{DynamicResource ABrush.Tone8.Background.Static}"
             Background="{DynamicResource ABrush.Tone1.Background.Static}"
             >

    <behaviors:Interaction.Triggers>
        <behaviors:EventTrigger EventName="Unloaded">
            <behaviors:InvokeCommandAction Command="{Binding SaveDefaultsCommand}" />
        </behaviors:EventTrigger>
    </behaviors:Interaction.Triggers>

    <!-- Design-time DataContext (so intellisense will work) -->
    <d:UserControl.DataContext>
        <viewmodels:DefaultSettingsViewModel/>
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Converters:BoolInverter x:Key="BoolInverter"/>

        <!-- Flyout-wide typography & spacing defaults -->
        <Style TargetType="TextBox" x:Key="FlyoutTextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="4,3"/>
        </Style>
        <Style TargetType="CheckBox" x:Key="FlyoutCheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>
        <Style TargetType="Label" x:Key="FlyoutLabel" BasedOn="{StaticResource {x:Type Label}}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style TargetType="ComboBox" x:Key="FlyoutComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style TargetType="ToggleButton" x:Key="FlyoutToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="6,3"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!--========== VERTICAL TAB STRIP ==========-->
        <StackPanel Grid.Column="0" VerticalAlignment="Top"
                    Background="{DynamicResource ABrush.Tone3.Background.Static}">

            <ToggleButton x:Name="btnAppearance" Padding="8,16" Margin="10">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Checked">
                        <behaviors:ChangePropertyAction TargetName="btnSpecies" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnThickness" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDoors" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDrawers" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnShelves" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnReveals" PropertyName="IsChecked" Value="False"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <TextBlock Text="Appearance" FontSize="14"/>
            </ToggleButton>

            <ToggleButton x:Name="btnSpecies" Padding="8,16" Margin="10">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Checked">
                        <behaviors:ChangePropertyAction TargetName="btnAppearance" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnThickness" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDoors" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDrawers" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnShelves" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnReveals" PropertyName="IsChecked" Value="False"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <TextBlock Text="Species" FontSize="14"/>
            </ToggleButton>

            <ToggleButton x:Name="btnThickness" Padding="8,16" Margin="10">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Checked">
                        <behaviors:ChangePropertyAction TargetName="btnAppearance" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnSpecies" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDoors" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDrawers" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnShelves" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnReveals" PropertyName="IsChecked" Value="False"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <TextBlock Text="Thickness &amp;&#xA;Top Type" FontSize="14" TextAlignment="Center"/>
            </ToggleButton>

            <ToggleButton x:Name="btnDoors" Padding="8,16" Margin="10">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Checked">
                        <behaviors:ChangePropertyAction TargetName="btnAppearance" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnSpecies" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnThickness" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDrawers" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnShelves" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnReveals" PropertyName="IsChecked" Value="False"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <TextBlock Text="Doors/Fronts" FontSize="14"/>
            </ToggleButton>

            <ToggleButton x:Name="btnDrawers" Padding="8,16" Margin="10">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Checked">
                        <behaviors:ChangePropertyAction TargetName="btnAppearance" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnSpecies" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnThickness" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDoors" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnShelves" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnReveals" PropertyName="IsChecked" Value="False"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <TextBlock Text="Drawers" FontSize="14"/>
            </ToggleButton>

            <ToggleButton x:Name="btnShelves" Padding="8,16" Margin="10">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Checked">
                        <behaviors:ChangePropertyAction TargetName="btnAppearance" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnSpecies" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnThickness" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDoors" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDrawers" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnReveals" PropertyName="IsChecked" Value="False"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <TextBlock Text="Shelves &amp;&#xA;Toekick" FontSize="14" TextAlignment="Center"/>
            </ToggleButton>

            <ToggleButton x:Name="btnReveals" Padding="8,16" Margin="10">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Checked">
                        <behaviors:ChangePropertyAction TargetName="btnAppearance" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnSpecies" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnThickness" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDoors" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnDrawers" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnShelves" PropertyName="IsChecked" Value="False"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <TextBlock Text="Reveals &amp;&#xA;Gaps" FontSize="14" TextAlignment="Center"/>
            </ToggleButton>
        </StackPanel>

        <!--========== APPEARANCE FLYOUT ==========-->
        <Border Grid.Column="1"
                ClipToBounds="True"
                Background="{DynamicResource ABrush.Tone2.Background.Static}"
                BorderBrush="{DynamicResource ABrush.Tone4.Border.Static}"
                BorderThickness="0,0,1,0"
                CornerRadius="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=btnAppearance}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="220" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Border Width="220" HorizontalAlignment="Left" Padding="10">
                <Border.Resources>
                    <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
                    <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
                </Border.Resources>
                <StackPanel>
                    <TextBlock Text="Appearance" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <Label Content="Theme" Margin="0,4,0,0"/>
                    <ComboBox ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding SelectedTheme}"
                              Width="150" HorizontalAlignment="Left" Margin="0,4,0,0"/>

                    <Separator Margin="0,16,0,12"/>

                    <Label Content="Dimension Format" Margin="0,0,0,0"/>
                    <ComboBox ItemsSource="{Binding ListDimensionFormat}" SelectedItem="{Binding DefaultDimensionFormat}"
                              Width="150" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Border>

        <!--========== SPECIES FLYOUT ==========-->
        <Border Grid.Column="1"
                ClipToBounds="True"
                Background="{DynamicResource ABrush.Tone2.Background.Static}"
                BorderBrush="{DynamicResource ABrush.Tone4.Border.Static}"
                BorderThickness="0,0,1,0"
                CornerRadius="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=btnSpecies}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="420" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Border Width="420" HorizontalAlignment="Left" Padding="10">
                <Border.Resources>
                    <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
                    <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
                </Border.Resources>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="Default Species" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <StackPanel Orientation="Horizontal">
                            <!-- Left column -->
                            <StackPanel Width="190" Margin="0,0,20,0">
                                <Label Content="Cabinet Species" Margin="0,4,0,0"/>
                                <ComboBox ItemsSource="{Binding ListCabSpecies}" SelectedItem="{Binding DefaultSpecies}"
                                          Margin="0,4,0,0"/>

                                <Label Content="Edgebanding" Margin="0,12,0,0"/>
                                <ComboBox ItemsSource="{Binding ListEBSpecies}" SelectedValue="{Binding DefaultEBSpecies}"
                                          Margin="0,4,0,0"/>

                                <Label Content="Door/Drw Front Species" Margin="0,12,0,0"/>
                                <ComboBox ItemsSource="{Binding ListCabSpecies}" SelectedValue="{Binding DefaultDoorDrwSpecies}"
                                          Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Right column -->
                            <StackPanel Width="190">
                                <Label Content="Filler Species" Margin="0,4,0,0"/>
                                <ComboBox ItemsSource="{Binding ListCabSpecies}" SelectedItem="{Binding DefaultFillerSpecies}"
                                          Margin="0,4,0,0"/>

                                <Label Content="Panel Species" Margin="0,12,0,0"/>
                                <ComboBox ItemsSource="{Binding ListCabSpecies}" SelectedValue="{Binding DefaultPanelSpecies}"
                                          Margin="0,4,0,0"/>

                                <Label Content="Panel Edgebanding" Margin="0,12,0,0"/>
                                <ComboBox ItemsSource="{Binding ListEBSpecies}" SelectedValue="{Binding DefaultPanelEBSpecies}"
                                          Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>

        <!--========== THICKNESS FLYOUT ==========-->
        <Border Grid.Column="1"
                ClipToBounds="True"
                Background="{DynamicResource ABrush.Tone2.Background.Static}"
                BorderBrush="{DynamicResource ABrush.Tone4.Border.Static}"
                BorderThickness="0,0,1,0"
                CornerRadius="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=btnThickness}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="220" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Border Width="220" HorizontalAlignment="Left" Padding="10">
                <Border.Resources>
                    <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
                    <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
                </Border.Resources>
                <StackPanel>
                    <TextBlock Text="Thickness" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <Label Content="Base Back Thickness" Margin="0,4,0,0"/>
                    <ComboBox ItemsSource="{Binding ListBackThickness}" SelectedItem="{Binding DefaultBaseBackThickness}"
                              Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"/>

                    <Label Content="Upper Back Thickness" Margin="0,12,0,0"/>
                    <ComboBox ItemsSource="{Binding ListBackThickness}" SelectedItem="{Binding DefaultUpperBackThickness}"
                              Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"/>

                    <Separator Margin="0,16,0,12"/>

                    <Label Content="Panel Thickness" Margin="0,0,0,0"/>
                    <ComboBox ItemsSource="{Binding ListBackThickness}" SelectedItem="{Binding DefaultPanelThickness}"
                              Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"/>

                    <Separator Margin="0,16,0,12"/>

                    <Label Content="Base Cabinet Top Type" Margin="0,0,0,0"/>
                    <ComboBox ItemsSource="{Binding ListTopType}" SelectedItem="{Binding DefaultTopType}"
                              Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Border>

        <!--========== DOORS/FRONTS FLYOUT ==========-->
        <Border Grid.Column="1"
                ClipToBounds="True"
                Background="{DynamicResource ABrush.Tone2.Background.Static}"
                BorderBrush="{DynamicResource ABrush.Tone4.Border.Static}"
                BorderThickness="0,0,1,0"
                CornerRadius="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=btnDoors}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="360" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Border Width="360" HorizontalAlignment="Left" Padding="10">
                <Border.Resources>
                    <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}"/>
                    <Style TargetType="CheckBox" BasedOn="{StaticResource FlyoutCheckBox}"/>
                    <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
                    <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
                    <Style TargetType="ToggleButton" BasedOn="{StaticResource FlyoutToggleButton}"/>
                </Border.Resources>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="Doors &amp; Drawer Fronts" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <CheckBox Content="Drill Hinge Plate Mounting Holes"
                                  IsChecked="{Binding DefaultDrillHingeHoles}"/>
                        <CheckBox Content="Include Doors In Door Sizes List"
                                  IsChecked="{Binding DefaultIncDoorsInList}"/>
                        <CheckBox Content="Include Slab Doors With Cabinet"
                                  IsChecked="{Binding DefaultIncDoors}"/>
                        <CheckBox Content="Include Drw Fronts In Door Sizes List"
                                  IsChecked="{Binding DefaultIncDrwFrontsInList}"/>
                        <CheckBox Content="Include Slab Drw Fronts With Cabinet"
                                  IsChecked="{Binding DefaultIncDrwFronts}"/>

                        <Separator Margin="0,10,0,8"/>

                        <Label Content="Door Grain Direction" Margin="0,0,0,0"/>
                        <ComboBox ItemsSource="{Binding ListGrainDirection}" SelectedItem="{Binding DefaultDoorGrainDir}"
                                  Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"/>

                        <Label Content="Drawer Front Grain Direction" Margin="0,10,0,0"/>
                        <ComboBox ItemsSource="{Binding ListGrainDirection}" SelectedItem="{Binding DefaultDrwGrainDir}"
                                  Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"/>

                        <Separator Margin="0,12,0,8"/>

                        <TextBlock Text="Default Drw. Front Heights" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,6"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="Top" Margin="0,2,0,0"/>
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     x:Name="textDefaultDrwFront1Height"
                                     Width="70" HorizontalAlignment="Left" Margin="0,2,0,0"
                                     Text="{Binding DefaultDrwFrontHeight1, UpdateSourceTrigger=PropertyChanged}"
                                     GotFocus="TextBoxGotFocus">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DefaultEqualizeAllDrwFronts}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <Label Grid.Row="1" Grid.Column="0" Content="Second" Margin="0,6,0,0"/>
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     x:Name="textDefaultDrwFront2Height"
                                     Width="70" HorizontalAlignment="Left" Margin="0,6,0,0"
                                     Text="{Binding DefaultDrwFrontHeight2, UpdateSourceTrigger=PropertyChanged}"
                                     GotFocus="TextBoxGotFocus">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DefaultEqualizeBottomDrwFronts}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding DefaultEqualizeAllDrwFronts}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <Label Grid.Row="2" Grid.Column="0" Content="Third" Margin="0,6,0,0"/>
                            <TextBox Grid.Row="2" Grid.Column="1"
                                     x:Name="textDefaultDrwFront3Height"
                                     Width="70" HorizontalAlignment="Left" Margin="0,6,0,0"
                                     Text="{Binding DefaultDrwFrontHeight3, UpdateSourceTrigger=PropertyChanged}"
                                     GotFocus="TextBoxGotFocus">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DefaultEqualizeBottomDrwFronts}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding DefaultEqualizeAllDrwFronts}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <ToggleButton Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                          Content="Equalize Bottom Drw. Fronts"
                                          IsChecked="{Binding DefaultEqualizeBottomDrwFronts}" Margin="0,8,0,0"/>
                            <ToggleButton Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                                          Content="Equalize All Drw. Fronts"
                                          IsChecked="{Binding DefaultEqualizeAllDrwFronts}" Margin="0,6,0,0"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>

        <!--========== DRAWERS FLYOUT ==========-->
        <Border Grid.Column="1"
                ClipToBounds="True"
                Background="{DynamicResource ABrush.Tone2.Background.Static}"
                BorderBrush="{DynamicResource ABrush.Tone4.Border.Static}"
                BorderThickness="0,0,1,0"
                CornerRadius="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=btnDrawers}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="340" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Border Width="340" HorizontalAlignment="Left" Padding="10">
                <Border.Resources>
                    <Style TargetType="CheckBox" BasedOn="{StaticResource FlyoutCheckBox}"/>
                    <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
                    <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
                </Border.Resources>
                <StackPanel>
                    <TextBlock Text="Drawers" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,20,0">
                            <Label Content="Std. Base Drw Count" Margin="0,4,0,0"/>
                            <ComboBox ItemsSource="{Binding ListStdDrwCount}" SelectedValue="{Binding DefaultStdDrawerCount}"
                                      Width="80" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel>
                            <Label Content="Drawer Base Drw Count" Margin="0,4,0,0"/>
                            <ComboBox ItemsSource="{Binding ListDrwStackDrwCount}" SelectedValue="{Binding DefaultDrawerStackDrawerCount}"
                                      Width="80" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Separator Margin="0,12,0,8"/>

                    <CheckBox Content="Drill Drawer Slide Holes In Cabinet"
                              IsChecked="{Binding DefaultDrillSlideHoles}"/>
                    <CheckBox Content="Include Drawer Boxes With Cabinet"
                              IsChecked="{Binding DefaultIncDrwBoxes}"/>
                    <CheckBox Content="Include Drawer Boxes in Drw Box Size List"
                              IsChecked="{Binding DefaultIncDrwBoxesInList}"/>

                    <Separator Margin="0,8,0,8"/>

                    <Label Content="Drawer Style" Margin="0,0,0,0"/>
                    <ComboBox ItemsSource="{Binding ListDrawerStyle}" SelectedValue="{Binding DefaultDrwStyle}"
                              Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Border>

        <!--========== SHELVES & TOEKICK FLYOUT ==========-->
        <Border Grid.Column="1"
                ClipToBounds="True"
                Background="{DynamicResource ABrush.Tone2.Background.Static}"
                BorderBrush="{DynamicResource ABrush.Tone4.Border.Static}"
                BorderThickness="0,0,1,0"
                CornerRadius="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=btnShelves}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="240" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Border Width="240" HorizontalAlignment="Left" Padding="10">
                <Border.Resources>
                    <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}"/>
                    <Style TargetType="CheckBox" BasedOn="{StaticResource FlyoutCheckBox}"/>
                    <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
                    <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
                </Border.Resources>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="Shelves" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <CheckBox Content="Drill Shelf Holes" IsChecked="{Binding DefaultDrillShelfHoles}" Margin="0,15,0,0"/>

                        <Separator Margin="0,14,0,10"/>

                        <Label Content="Base Shelf Count" Margin="0,4,0,0"/>
                        <ComboBox ItemsSource="{Binding ListShelfCount}" SelectedValue="{Binding DefaultShelfCount}"
                                  Width="80" HorizontalAlignment="Left" Margin="0,4,0,0"/>

                        <Label Content="Base Shelf Depth" Margin="0,8,0,0"/>
                        <ComboBox ItemsSource="{Binding ListShelfDepth}" SelectedItem="{Binding DefaultShelfDepth}"
                                  Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                        <TextBlock Text="Shelf Depth only applies to Base cabinet types." FontSize="12"
                                   TextWrapping="Wrap" Margin="0,4,0,0" Foreground="Gray"/>

                        <Separator Margin="0,10,0,8"/>

                        <Label Content="Upper Shelf Count" Margin="0,0,0,0"/>
                        <ComboBox ItemsSource="{Binding ListShelfCount}" SelectedValue="{Binding DefaultUpperShelfCount}"
                                  Width="80" HorizontalAlignment="Left" Margin="0,4,0,0"/>

                        <Separator Margin="0,14,0,12"/>

                        <TextBlock Text="Toekick" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <CheckBox Content="Has Toekick" IsChecked="{Binding DefaultHasTK}"/>

                        <Label Content="Toekick Height" Margin="0,8,0,0"/>
                        <TextBox x:Name="textDefaultTKHeight" Width="70" HorizontalAlignment="Left" Margin="0,4,0,0"
                                 Text="{Binding DefaultTKHeight}" GotFocus="TextBoxGotFocus"/>

                        <Label Content="Toekick Depth" Margin="0,8,0,0"/>
                        <TextBox x:Name="textDefaultTKDepth" Width="70" HorizontalAlignment="Left" Margin="0,4,0,0"
                                 Text="{Binding DefaultTKDepth}" GotFocus="TextBoxGotFocus"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>

        <!--========== REVEALS & GAPS FLYOUT ==========-->
        <Border Grid.Column="1"
                ClipToBounds="True"
                Background="{DynamicResource ABrush.Tone2.Background.Static}"
                BorderBrush="{DynamicResource ABrush.Tone4.Border.Static}"
                BorderThickness="0,0,1,0"
                CornerRadius="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=btnReveals}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="360" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Border Width="360" HorizontalAlignment="Left" Padding="10">
                <Border.Resources>
                    <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}"/>
                    <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
                </Border.Resources>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="Reveals &amp; Gaps" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

                        <TextBlock Text="Base Cabinets" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,6"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="Left Reveal"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Width="70" HorizontalAlignment="Left" Margin="0,2,0,4"
                                     Text="{Binding DefaulBasetLeftReveal}" GotFocus="TextBoxGotFocus"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Rec: 0.0625" FontSize="12" FontStyle="Italic"
                                       VerticalAlignment="Center" Foreground="Gray"/>

                            <Label Grid.Row="1" Grid.Column="0" Content="Right Reveal"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Width="70" HorizontalAlignment="Left" Margin="0,2,0,4"
                                     Text="{Binding DefaultBaseRightReveal}" GotFocus="TextBoxGotFocus"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Rec: 0.0625" FontSize="12" FontStyle="Italic"
                                       VerticalAlignment="Center" Foreground="Gray"/>

                            <Label Grid.Row="2" Grid.Column="0" Content="Top Reveal"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Width="70" HorizontalAlignment="Left" Margin="0,2,0,4"
                                     Text="{Binding DefaultBaseTopReveal}" GotFocus="TextBoxGotFocus"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Rec: 0.4375" FontSize="12" FontStyle="Italic"
                                       VerticalAlignment="Center" Foreground="Gray"/>

                            <Label Grid.Row="3" Grid.Column="0" Content="Bottom Reveal"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Width="70" HorizontalAlignment="Left" Margin="0,2,0,4"
                                     Text="{Binding DefaultBaseBottomReveal}" GotFocus="TextBoxGotFocus"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="Rec: 0.0625" FontSize="12" FontStyle="Italic"
                                       VerticalAlignment="Center" Foreground="Gray"/>
                        </Grid>

                        <Separator Margin="0,10,0,8"/>

                        <TextBlock Text="Upper Cabinets" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,6"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Content="Left Reveal"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Width="70" HorizontalAlignment="Left" Margin="0,2,0,4"
                                     Text="{Binding DefaultUpperLeftReveal}" GotFocus="TextBoxGotFocus"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Rec: 0.0625" FontSize="12" FontStyle="Italic"
                                       VerticalAlignment="Center" Foreground="Gray"/>

                            <Label Grid.Row="1" Grid.Column="0" Content="Right Reveal"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Width="70" HorizontalAlignment="Left" Margin="0,2,0,4"
                                     Text="{Binding DefaultUpperRightReveal}" GotFocus="TextBoxGotFocus"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Rec: 0.0625" FontSize="12" FontStyle="Italic"
                                       VerticalAlignment="Center" Foreground="Gray"/>

                            <Label Grid.Row="2" Grid.Column="0" Content="Top Reveal"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Width="70" HorizontalAlignment="Left" Margin="0,2,0,4"
                                     Text="{Binding DefaultUpperTopReveal}" GotFocus="TextBoxGotFocus"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="Rec: 0.125" FontSize="12" FontStyle="Italic"
                                       VerticalAlignment="Center" Foreground="Gray"/>

                            <Label Grid.Row="3" Grid.Column="0" Content="Bottom Reveal"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Width="70" HorizontalAlignment="Left" Margin="0,2,0,4"
                                     Text="{Binding DefaultUpperBottomReveal}" GotFocus="TextBoxGotFocus"/>
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="Rec: 0.125" FontSize="12" FontStyle="Italic"
                                       VerticalAlignment="Center" Foreground="Gray"/>
                        </Grid>

                        <Separator Margin="0,10,0,8"/>

                        <TextBlock Text="All Cabinets" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,6"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Column="0" Content="Door Gaps"/>
                            <TextBox Grid.Column="1" Width="70" HorizontalAlignment="Left" Margin="0,2,0,4"
                                     Text="{Binding DefaultGapWidth}" GotFocus="TextBoxGotFocus"/>
                            <TextBlock Grid.Column="2" Text="Rec: 0.125" FontSize="12" FontStyle="Italic"
                                       VerticalAlignment="Center" Foreground="Gray"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>

        <!--========== MAIN CONTENT AREA ==========-->
        <Grid Grid.Column="2" Margin="20">
            <StackPanel VerticalAlignment="Bottom">
                <TextBlock Text="NOTES" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="Gray">
                    Toekick Height only applies to base cabinets with integrated toekicks. It does not apply to "No Toekick" cabinets.
                    Toekick Depth does not include the thickness of any applied face frame or toekick skin board.
                    <LineBreak/><LineBreak/>
                    IMPORTANT: Be sure you know what you are doing if you are setting custom door/drawer front reveal values. Incorrect values will result
                    in incorrectly sized doors and drawer fronts!
                    <LineBreak/>
                    Corlane will not be held responsible for incorrect door/drawer front sizes as a result of deviating from our recommended values.
                </TextBlock>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>