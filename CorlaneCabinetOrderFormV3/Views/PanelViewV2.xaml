<UserControl x:Class="CorlaneCabinetOrderFormV3.Views.PanelViewV2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CorlaneCabinetOrderFormV3.Views"
             xmlns:viewmodels="clr-namespace:CorlaneCabinetOrderFormV3.ViewModels"    
             xmlns:Converters="clr-namespace:CorlaneCabinetOrderFormV3.Converters"
             xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:appbehaviors="clr-namespace:CorlaneCabinetOrderFormV3.Behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="960" d:DesignWidth="1000"
             d:Background="{DynamicResource ABrush.Tone8.Background.Static}"
             Background="{DynamicResource ABrush.Tone1.Background.Static}"
             >
    <!-- Design-time DataContext (so intellisense will work) -->
    <d:UserControl.DataContext>
        <viewmodels:PanelViewModel/>
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Converters:BoolInverter x:Key="BoolInverter"/>
        <Converters:StringToIntConverter x:Key="StringToIntConverter"/>

        <!-- Flyout-wide typography & spacing defaults -->
        <Style TargetType="TextBox" x:Key="FlyoutTextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="4,3"/>
        </Style>
        <Style TargetType="CheckBox" x:Key="FlyoutCheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>
        <Style TargetType="Label" x:Key="FlyoutLabel" BasedOn="{StaticResource {x:Type Label}}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style TargetType="ComboBox" x:Key="FlyoutComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style TargetType="ListBox" x:Key="FlyoutListBox" BasedOn="{StaticResource {x:Type ListBox}}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="6,3"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <!-- Vertical tab strip -->
            <ColumnDefinition Width="Auto"/>
            <!-- Flyout panel (animated width) -->
            <ColumnDefinition Width="*"/>
            <!-- Main content area -->
        </Grid.ColumnDefinitions>

        <!--========== VERTICAL TAB STRIP ==========-->
        <StackPanel Grid.Column="0" VerticalAlignment="Top"
                    Background="{DynamicResource ABrush.Tone3.Background.Static}">

            <ToggleButton x:Name="btnDimensions" Padding="8,16" Margin="10">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Checked">
                        <behaviors:ChangePropertyAction TargetName="btnSpecies" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnEdges" PropertyName="IsChecked" Value="False"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <TextBlock Text="Dimensions" FontSize="14"/>
            </ToggleButton>

            <ToggleButton x:Name="btnSpecies" Padding="8,16" Margin="10">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Checked">
                        <behaviors:ChangePropertyAction TargetName="btnDimensions" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnEdges" PropertyName="IsChecked" Value="False"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <TextBlock Text="Species" FontSize="14"/>
            </ToggleButton>

            <ToggleButton x:Name="btnEdges" Padding="8,16" Margin="10">
                <behaviors:Interaction.Triggers>
                    <behaviors:EventTrigger EventName="Checked">
                        <behaviors:ChangePropertyAction TargetName="btnDimensions" PropertyName="IsChecked" Value="False"/>
                        <behaviors:ChangePropertyAction TargetName="btnSpecies" PropertyName="IsChecked" Value="False"/>
                    </behaviors:EventTrigger>
                </behaviors:Interaction.Triggers>
                <TextBlock Text="Edgebanding" FontSize="14"/>
            </ToggleButton>
        </StackPanel>

        <!--========== DIMENSIONS FLYOUT ==========-->
        <Border Grid.Column="1"
                ClipToBounds="True"
                Background="{DynamicResource ABrush.Tone2.Background.Static}"
                BorderBrush="{DynamicResource ABrush.Tone4.Border.Static}"
                BorderThickness="0,0,1,0"
                CornerRadius="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=btnDimensions}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="220" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Border Width="220" HorizontalAlignment="Left" Padding="10">
                <Border.Resources>
                    <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}"/>
                    <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
                    <Style TargetType="ComboBox" BasedOn="{StaticResource FlyoutComboBox}"/>
                </Border.Resources>
                <StackPanel>
                    <TextBlock Text="Dimensions" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <!-- Width -->
                    <Label Content="Width" Margin="0,4,0,0"/>
                    <TextBox x:Name="textWidthPanel" Width="120" HorizontalAlignment="Left"
                             Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="TextBoxGotFocus"
                             appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                    <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                               Visibility="{Binding (Validation.HasError), ElementName=textWidthPanel, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textWidthPanel, FallbackValue=''}"/>

                    <!-- Height -->
                    <Label Content="Height" Margin="0,8,0,0"/>
                    <TextBox x:Name="textHeightPanel" Width="120" HorizontalAlignment="Left"
                             Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}"
                             GotFocus="TextBoxGotFocus"
                             appbehaviors:DimensionAutoFormat.IsEnabled="True"/>
                    <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                               Visibility="{Binding (Validation.HasError), ElementName=textHeightPanel, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textHeightPanel, FallbackValue=''}"/>

                    <!-- Thickness -->
                    <Label Content="Thickness" Margin="0,8,0,0"/>
                    <ComboBox x:Name="comboDepthPanel" Width="80" HorizontalAlignment="Left"
                              ItemsSource="{Binding ListPanelDepths}"
                              Text="{Binding Depth, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock FontSize="12" Foreground="Red" Margin="0,2,0,0"
                               Visibility="{Binding (Validation.HasError), ElementName=comboDepthPanel, Converter={StaticResource BoolToVisibilityConverter}}"
                               Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=comboDepthPanel, FallbackValue=''}"/>
                </StackPanel>
            </Border>
        </Border>

        <!--========== SPECIES FLYOUT ==========-->
        <Border Grid.Column="1"
                ClipToBounds="True"
                Background="{DynamicResource ABrush.Tone2.Background.Static}"
                BorderBrush="{DynamicResource ABrush.Tone4.Border.Static}"
                BorderThickness="0,0,1,0"
                CornerRadius="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=btnSpecies}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="500" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Border Width="500" HorizontalAlignment="Left" Padding="10">
                <Border.Resources>
                    <Style TargetType="TextBox" BasedOn="{StaticResource FlyoutTextBox}"/>
                    <Style TargetType="Label" BasedOn="{StaticResource FlyoutLabel}"/>
                    <Style TargetType="ListBox" BasedOn="{StaticResource FlyoutListBox}"/>
                </Border.Resources>
                <StackPanel>
                    <TextBlock Text="Species" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal">
                        <!-- Panel Species -->
                        <StackPanel Width="210" Margin="0,0,30,0">
                            <TextBlock Text="Panel Species" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ListBox ItemsSource="{Binding ListCabSpecies}"
                                     SelectedItem="{Binding Species}"/>
                            <Label Content="Custom Species:" Margin="0,6,0,0" Padding="0"/>
                            <TextBox Text="{Binding CustomSpecies}" HorizontalAlignment="Stretch" Margin="0,4,0,0"
                                     IsEnabled="{Binding CustomCabSpeciesEnabled}"/>
                        </StackPanel>

                        <!-- Edgebanding Species -->
                        <StackPanel Width="230">
                            <TextBlock Text="Edgebanding" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <ListBox ItemsSource="{Binding ListEBSpecies}"
                                     SelectedItem="{Binding EBSpecies}"/>
                            <Label Content="Custom Edgebanding:" Margin="0,6,0,0" Padding="0"/>
                            <TextBox Text="{Binding CustomEBSpecies}" HorizontalAlignment="Stretch" Margin="0,4,0,0"
                                     IsEnabled="{Binding CustomEBSpeciesEnabled}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!--========== EDGEBANDING EDGES FLYOUT ==========-->
        <Border Grid.Column="1"
                ClipToBounds="True"
                Background="{DynamicResource ABrush.Tone2.Background.Static}"
                BorderBrush="{DynamicResource ABrush.Tone4.Border.Static}"
                BorderThickness="0,0,1,0"
                CornerRadius="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChecked, ElementName=btnEdges}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="320" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width"
                                                         To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseIn"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Border Width="320" HorizontalAlignment="Left" Padding="10">
                <Border.Resources>
                    <Style TargetType="CheckBox" BasedOn="{StaticResource FlyoutCheckBox}"/>
                </Border.Resources>
                <StackPanel>
                    <TextBlock Text="Edgebanded Edges" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <CheckBox Content="Top" HorizontalAlignment="Center" Margin="0,15,0,5"
                              IsChecked="{Binding PanelEBTop}"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <CheckBox Content="Left" VerticalAlignment="Center" Margin="10,0,0,0"
                                  IsChecked="{Binding PanelEBLeft}"/>
                        <Image Source="/Images/woodgrain.PNG" Width="150" Height="200" Margin="10,0,10,0"/>
                        <CheckBox Content="Right" VerticalAlignment="Center" Margin="0,0,10,0"
                                  IsChecked="{Binding PanelEBRight}"/>
                    </StackPanel>

                    <CheckBox Content="Bottom" HorizontalAlignment="Center" Margin="0,5,0,20"
                              IsChecked="{Binding PanelEBBottom}"/>
                </StackPanel>
            </Border>
        </Border>

        <!--========== MAIN CONTENT AREA ==========-->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

			<!-- 3D viewport is placed here programmatically by MainWindow -->
			<Border x:Name="ViewportHost" Grid.Row="0"/>
			
            <!--===== BOTTOM ACTION PANEL =====-->
            <Border Grid.Row="1"
                    Background="{DynamicResource ABrush.Tone2.Background.Static}"
                    BorderBrush="{DynamicResource ABrush.Tone4.Border.Static}"
                    BorderThickness="0,1,0,0"
                    Padding="16,12"
                    CornerRadius="10,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!--== LEFT: Load Defaults ==-->
                    <Button Grid.Column="0" Content="Load Defaults" FontSize="16" Padding="10,4"
                            VerticalAlignment="Center"
                            Command="{Binding LoadDefaultsCommand}"/>

                    <!--== CENTER: Special instructions ==-->
                    <StackPanel Grid.Column="1" Margin="24,0">
                        <TextBlock Text="Special Instructions / Notes" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="textPanelNotes" MinHeight="100" MaxHeight="100"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 FontSize="14"
                                 Text="{Binding Notes}"/>
                    </StackPanel>

                    <!--== RIGHT: Qty / Name / Add / Update ==-->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
                            <TextBlock Text="Qty:" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="textQty" Width="50" FontSize="16" VerticalAlignment="Center"
                                     Text="{Binding Qty, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource StringToIntConverter}}"
                                     GotFocus="TextBoxGotFocus"/>
                        </StackPanel>
                        <TextBlock FontSize="12" Foreground="Red" HorizontalAlignment="Right" Margin="0,0,0,4"
                                   Visibility="{Binding (Validation.HasError), ElementName=textQty, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Text="{Binding (Validation.Errors)[0].ErrorContent, ElementName=textQty, FallbackValue=''}"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                            <TextBlock Text="Name:" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="textName" Width="150" FontSize="16" VerticalAlignment="Center"
                                     Text="{Binding Name}" GotFocus="TextBoxGotFocus"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="buttonAdd" Content="Add to List" FontSize="16" Padding="12,6" Margin="0,0,8,0"
                                    IsEnabled="{Binding HasErrors, Converter={StaticResource BoolInverter}}"
                                    Command="{Binding AddCabinetCommand}"/>
                            <Button x:Name="buttonUpdate" Content="Update in List" FontSize="16" Padding="12,6"
                                    IsEnabled="{Binding HasErrors, Converter={StaticResource BoolInverter}}"
                                    Command="{Binding UpdateCabinetCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>